---
// ═══════════════════════════════════════════════════════════
//  Layout.astro — SEO-optimised base layout with native i18n
//  Kevin Gómez Lázaro · Full Stack Developer · Lima, Perú
// ═══════════════════════════════════════════════════════════
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const locale = (Astro.currentLocale || "es") as "es" | "en";
const isEn = locale === "en";

const siteURL = "https://kevin-gomez.dev";
const canonicalURL = isEn ? `${siteURL}/en/` : `${siteURL}/`;

const {
  title = isEn
    ? "Kevin Gómez | Full Stack Developer Lima, Peru — Next.js · React · NestJS"
    : "Kevin Gómez | Full Stack Developer Lima, Perú — Next.js · React · NestJS",
  description = isEn
    ? "Full Stack Developer with 8+ years of experience in Lima, Peru. Specialist in Next.js, React, NestJS, Headless WordPress, Laravel and E-Commerce. Projects for Entel, NERD, Well-Done. Available for freelance."
    : "Full Stack Developer con 8+ años de experiencia en Lima, Perú. Especialista en Next.js, React, NestJS, WordPress Headless, Laravel y E-Commerce. Proyectos para Entel, NERD, Well-Done. Disponible para freelance.",
  ogImage = `${siteURL}/og-image.jpg`,
} = Astro.props;

const keywords = isEn
  ? "full stack developer lima peru, web developer peru, next.js developer peru, react developer lima, nestjs developer, headless wordpress, laravel developer peru, ecommerce developer, freelance developer peru, kevin gomez"
  : "full stack developer lima peru, desarrollador web lima, next.js developer peru, react developer lima, nestjs developer, wordpress headless, laravel developer peru, ecommerce developer, desarrollador freelance lima, kevin gomez";

// ─── JSON-LD Structured Data ───
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteURL}/#person`,
      name: "Kevin Gómez Lázaro",
      givenName: "Kevin",
      familyName: "Gómez Lázaro",
      jobTitle: "Full Stack Developer",
      description:
        "Full Stack Developer con 8+ años de experiencia en Lima, Perú. Especialista en Next.js, React, NestJS, WordPress Headless, Laravel y soluciones e-commerce.",
      url: siteURL,
      email: "kevin94897@gmail.com",
      telephone: "+51947841355",
      image: ogImage,
      address: {
        "@type": "PostalAddress",
        addressLocality: "Lima",
        addressRegion: "Lima",
        addressCountry: "PE",
      },
      sameAs: ["https://github.com/kevin94897/"],
      knowsAbout: [
        "Next.js",
        "React",
        "NestJS",
        "WordPress Headless",
        "Laravel",
        "Node.js",
        "Astro",
        "PHP",
        "TypeScript",
        "SEO Técnico",
        "E-Commerce",
        "Shopify",
        "WooCommerce",
      ],
      hasCredential: [
        {
          "@type": "EducationalOccupationalCredential",
          name: "Ingeniería de Sistemas — Bachiller",
          recognizedBy: {
            "@type": "Organization",
            name: "Universidad Nacional del Callao",
          },
        },
        {
          "@type": "EducationalOccupationalCredential",
          name: "Scrum Foundation Professional Certificate (SFPC)",
          description: "Score: 95/100",
        },
      ],
    },
    {
      "@type": "ProfessionalService",
      "@id": `${siteURL}/#service`,
      name: "Kevin Gómez — Full Stack Developer & Web Agency",
      description:
        "Servicios de desarrollo web Full Stack, e-commerce, SEO técnico y diseño UX en Lima, Perú. Disponible para proyectos freelance y colaboraciones remotas.",
      url: siteURL,
      provider: { "@id": `${siteURL}/#person` },
      areaServed: [
        { "@type": "City", name: "Lima" },
        { "@type": "Country", name: "Perú" },
        { "@type": "AdministrativeArea", name: "América Latina" },
      ],
      priceRange: "S/. 850 – S/. 1,650",
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Planes de Desarrollo Web",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Sitio Web Básico" },
            price: "850",
            priceCurrency: "PEN",
          },
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Sitio Corporativo" },
            price: "1200",
            priceCurrency: "PEN",
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Tienda Virtual E-Commerce",
            },
            price: "1650",
            priceCurrency: "PEN",
          },
        ],
      },
    },
    {
      "@type": "WebSite",
      "@id": `${siteURL}/#website`,
      url: siteURL,
      name: "Kevin Gómez — Full Stack Developer",
      description:
        "Portfolio profesional de Kevin Gómez Lázaro, Full Stack Developer en Lima, Perú.",
      inLanguage: ["es-PE", "en"],
      author: { "@id": `${siteURL}/#person` },
    },
  ],
};
---

<!doctype html>
<html lang={locale} dir="ltr">
  <head>
    <!-- ─── Charset & Viewport ─── -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ─── Primary SEO ─── -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Kevin Gómez Lázaro" />
    <meta
      name="robots"
      content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />
    <meta name="theme-color" content="#b4df00" />

    <!-- ─── Canonical ─── -->
    <link rel="canonical" href={canonicalURL} />

    <!-- ─── Open Graph ─── -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta
      property="og:site_name"
      content="Kevin Gómez — Full Stack Developer"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Kevin Gómez — Full Stack Developer Lima, Perú"
    />
    <meta property="og:locale" content={isEn ? "en_US" : "es_PE"} />
    <meta property="og:locale:alternate" content={isEn ? "es_PE" : "en_US"} />

    <!-- ─── Twitter Card ─── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta
      name="twitter:image:alt"
      content="Kevin Gómez — Full Stack Developer"
    />

    <!-- ─── Geo / Local SEO ─── -->
    <meta name="geo.region" content="PE-LIM" />
    <meta name="geo.placename" content="Lima, Perú" />
    <meta name="language" content={isEn ? "English" : "Spanish"} />
    <meta name="revisit-after" content="7 days" />

    <!-- ─── hreflang — alternate language URLs ─── -->
    <link rel="alternate" hreflang="es" href={`${siteURL}/`} />
    <link rel="alternate" hreflang="en" href={`${siteURL}/en/`} />
    <link rel="alternate" hreflang="x-default" href={`${siteURL}/`} />

    <!-- ─── Fonts: self-hosted woff2 — preloaded, zero external requests ─── -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- ─── Icons: Phosphor — async (non-render-blocking) ─── -->
    <link
      rel="stylesheet"
      href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css"
      media="print"
    />
    <link
      rel="stylesheet"
      href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/bold/style.css"
      media="print"
    />
    <noscript>
      <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css" />
      <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/bold/style.css" />
    </noscript>
    <!-- Switch media to 'all' after load so icons/fonts apply without blocking -->
    <script is:inline>
      document.querySelectorAll('link[media="print"]').forEach(function(l){
        l.addEventListener('load', function(){ l.media = 'all'; });
        if(l.sheet) l.media = 'all';
      });
    </script>

    <!-- ─── Favicon ─── -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- ─── Sitemap ─── -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- ─── Structured Data (JSON-LD) ─── -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData, null, 2)}
    />

    <!-- ─── Hero intro: scroll-restoration setup + JS-fail safety net ─── -->
    <noscript><style>{`#hero-intro-cover{display:none!important}.hero-title-anim{visibility:visible!important}[data-hero-reveal]{opacity:1!important}`}</style></noscript>
    <script is:inline>
      try {
        // Take over scroll restoration so the intro decision is deterministic.
        // The browser's default "auto" restores scrollY only AFTER this
        // deferred context runs, so reading scrollY in the module would report
        // 0 on a mid-page reload and wrongly play the hero intro in another
        // section. With "manual" we restore the saved position ourselves (from
        // sessionStorage) and gate the intro on whether that position is inside
        // the #hero section.
        if ("scrollRestoration" in history) history.scrollRestoration = "manual";

        // Landing on an inner section via anchor (e.g. /#contact) → no intro.
        var h = location.hash;
        if (h && h.length > 1 && h !== "#hero" && h !== "#main-content") {
          window.__skipIntro = true;
        }
      } catch (e) {}
      // If the animation module never runs, force-reveal the hero pieces after
      // 6s so the page is never left invisible.
      window.__introFallback = setTimeout(function () {
        var cv = document.getElementById("hero-intro-cover");
        if (cv) cv.style.display = "none";
        var ht = document.querySelector(".hero-title-anim");
        if (ht) { ht.style.opacity = "1"; ht.style.visibility = "visible"; }
        document.querySelectorAll("[data-hero-reveal]").forEach(function (el) {
          el.style.opacity = "1";
        });
      }, 6000);
    </script>
  </head>

  <body>
    <!-- Accessibility: skip to main content -->
    <a href="#main-content" class="skip-link"
      >{isEn ? "Skip to main content" : "Saltar al contenido principal"}</a
    >

    <slot />

    <!-- GSAP title animations -->
    <script>
      import Lenis from "lenis";
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import { SplitText } from "gsap/SplitText";

      gsap.registerPlugin(ScrollTrigger, SplitText);

      // ── Lenis smooth scroll ─────────────────────────────────
      const BASE_LERP = 0.09; // interpolation — lower = smoother/slower
      const BASE_WHEEL = 0.85;
      // Near the bottom the scroll eases into a slower, smoother glide.
      const SLOW_LERP = 0.045;
      const SLOW_WHEEL = 0.5;
      const SLOW_FROM = 0.82; // progress (0–1) where the slowdown begins

      const lenis = new Lenis({
        lerp: BASE_LERP,
        smoothWheel: true,
        wheelMultiplier: BASE_WHEEL,
        touchMultiplier: 1.5,
        syncTouch: false, // mobile uses native scroll
      });

      // Keep GSAP ScrollTrigger in sync with Lenis + slow down near the end.
      lenis.on("scroll", (e: any) => {
        ScrollTrigger.update();
        const progress: number =
          (e && typeof e.progress === "number" ? e.progress : lenis.progress) ||
          0;
        if (progress >= SLOW_FROM) {
          const t = (progress - SLOW_FROM) / (1 - SLOW_FROM); // 0 → 1
          const eased = t * t * (3 - 2 * t); // smoothstep
          (lenis as any).options.lerp = BASE_LERP - (BASE_LERP - SLOW_LERP) * eased;
          (lenis as any).options.wheelMultiplier =
            BASE_WHEEL - (BASE_WHEEL - SLOW_WHEEL) * eased;
        } else {
          (lenis as any).options.lerp = BASE_LERP;
          (lenis as any).options.wheelMultiplier = BASE_WHEEL;
        }
      });
      gsap.ticker.add((time) => lenis.raf(time * 1000));
      gsap.ticker.lagSmoothing(0);

      // Allow other components to pause/resume Lenis (e.g. scroll-hijack sections)
      document.addEventListener("lenis:stop", () => lenis.stop());
      document.addEventListener("lenis:start", () => lenis.start());

      function wrapLines(lines: Element[]) {
        lines.forEach((line) => {
          const wrap = document.createElement("div");
          wrap.style.overflow = "hidden";
          wrap.style.display = "block";
          // Extra space below the clip boundary so descenders (y, j, g, p…)
          // are not cut off. Negative margin keeps the overall layout spacing.
          wrap.style.paddingBottom = "0.25em";
          wrap.style.marginBottom = "-0.25em";
          line.parentNode!.insertBefore(wrap, line);
          wrap.appendChild(line);
        });
      }

      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      const heroTitle = document.querySelector<HTMLElement>(".hero-title-anim");
      // Hide the hero title until the intro takes over, so it never flashes
      // in its final spot before the entrance animation runs.
      if (heroTitle) gsap.set(heroTitle, { autoAlpha: 0 });

      // ── Hero title fallback reveal (used when the intro is skipped) ──
      function animateHeroTitle() {
        if (!heroTitle) return;
        gsap.set(heroTitle, { autoAlpha: 1 });
        const split = new SplitText(heroTitle, { type: "lines" });
        wrapLines(split.lines);
        gsap.from(split.lines, {
          y: "115%",
          stagger: 0.1,
          duration: 1.15,
          delay: 0.2,
          ease: "power4.out",
        });
      }

      // ── Hero sub-elements — ordered reveal (tech → roles → secondary) ──
      function animateHeroExtras() {
        const allHeroEls =
          document.querySelectorAll<HTMLElement>("[data-hero-reveal]");
        const techEl = document.querySelector<HTMLElement>(
          '[data-hero-reveal="tech"]',
        );
        const rolesEl = document.querySelector<HTMLElement>(
          '[data-hero-reveal="roles"]',
        );
        const secondaryEls = document.querySelectorAll<HTMLElement>(
          '[data-hero-reveal="secondary"]',
        );

        if (!allHeroEls.length) return;
        gsap.set(allHeroEls, { opacity: 0, y: 18 });

        const tl = gsap.timeline();
        if (techEl)
          tl.to(techEl, { opacity: 1, y: 0, duration: 0.6, ease: "power2.out" }, 0);
        if (rolesEl)
          tl.to(rolesEl, { opacity: 1, y: 0, duration: 0.6, ease: "power2.out" }, 0.22);
        if (secondaryEls.length)
          tl.to(
            secondaryEls,
            { opacity: 1, y: 0, stagger: 0.12, duration: 0.55, ease: "power2.out" },
            0.44,
          );
        tl.call(
          () => document.dispatchEvent(new CustomEvent("hero:reveal-spline")),
          undefined,
          0.85,
        );
      }

      // ── Intro entrance — hero name brightens in place (no takeover) ──
      clearTimeout((window as any).__introFallback);

      const mainName = heroTitle?.querySelector<HTMLElement>(".hero-name-main");
      const suffixName =
        heroTitle?.querySelector<HTMLElement>(".hero-name-suffix") ?? null;

      // Play the intro only when the saved scroll position lies within the
      // #hero section (this also covers a fresh load at the very top). The
      // position comes from sessionStorage — not window.scrollY — because the
      // browser hasn't applied the restored scroll yet at this point.
      const heroSection = document.getElementById("hero");
      const heroBottom = heroSection
        ? heroSection.offsetTop + heroSection.offsetHeight
        : window.innerHeight;
      const hasHash = location.hash.length > 1;
      let savedY = 0;
      try {
        savedY = parseFloat(sessionStorage.getItem("__scrollY") || "0") || 0;
      } catch (_e) {}

      // Restore the previous scroll position ourselves (manual restoration
      // won't), unless an anchor link is already handling the scroll. The page
      // is never locked, so the intro simply plays wherever #hero ends up.
      if (!hasHash && savedY > 4) {
        window.scrollTo(0, savedY);
        lenis.scrollTo(savedY, { immediate: true });
      }

      const playIntro =
        !(window as any).__skipIntro && !hasHash && savedY < heroBottom - 4;

      const cover = document.getElementById("hero-intro-cover");

      if (!heroTitle || !mainName || prefersReduced || !playIntro) {
        // Reveal the hero without the cinematic entrance (reduced motion,
        // missing nodes, anchor nav, or we're in another section).
        if (cover) cover.style.display = "none";
        animateHeroTitle();
        animateHeroExtras();
      } else {
        // Cinematic entrance scoped to #hero: a black backdrop covers the
        // hero, the name brightens centered on it, then flows to its real
        // position as the backdrop fades. No scroll lock, no full-screen
        // takeover — the cover lives inside #hero and scrolls with it.
        const heroRect = heroSection
          ? heroSection.getBoundingClientRect()
          : ({ left: 0, top: 0, width: window.innerWidth, height: window.innerHeight } as DOMRect);
        const titleRect = heroTitle.getBoundingClientRect();
        // Center the VISIBLE name (text, not the full-width h1 box) in the hero.
        const dx =
          heroRect.left + heroRect.width / 2 -
          (titleRect.left + mainName.offsetWidth / 2);
        const dy =
          heroRect.top + heroRect.height / 2 -
          (titleRect.top + titleRect.height / 2);

        // Lift the name's container above the cover (raising the h1 alone is
        // capped by its z-10 parent's stacking context).
        const nameWrap =
          heroTitle.closest<HTMLElement>("[data-hero-name-wrap]");
        if (nameWrap) gsap.set(nameWrap, { position: "relative", zIndex: 50 });

        gsap.set(heroTitle, {
          opacity: 1,
          visibility: "visible",
          x: dx,
          y: dy,
          scale: 1.12,
          transformOrigin: "center center",
        });
        if (suffixName) gsap.set(suffixName, { autoAlpha: 0 });
        const split = new SplitText(mainName, {
          type: "chars",
          charsClass: "char",
        });
        gsap.set(split.chars, { opacity: 0.3 });

        const intro = gsap.timeline({
          onComplete: () => {
            split.revert();
            gsap.set(heroTitle, { clearProps: "transform" });
            if (nameWrap) gsap.set(nameWrap, { clearProps: "zIndex" });
            if (cover) cover.style.display = "none";
            ScrollTrigger.refresh();
          },
        });
        intro
          // Letters brighten left→right, centered on the black backdrop.
          .to(split.chars, {
            opacity: 1,
            duration: 0.55,
            ease: "power1.out",
            stagger: { each: 0.16 },
          })
          .addLabel("flow", "+=0.4")
          // Name flows to its real position (transforms → 0).
          .to(
            heroTitle,
            { x: 0, y: 0, scale: 1, duration: 1.3, ease: "power3.inOut" },
            "flow",
          );
        // Backdrop fades, revealing the hero behind the moving name.
        if (cover) {
          intro.to(
            cover,
            { autoAlpha: 0, duration: 1, ease: "power2.inOut" },
            "flow+=0.1",
          );
        }
        if (suffixName) {
          intro.to(
            suffixName,
            { autoAlpha: 1, duration: 0.6, ease: "power2.out" },
            "flow+=0.6",
          );
        }
        // Reveal the rest of the hero as the name settles.
        intro.add(() => animateHeroExtras(), "flow+=0.3");
      }

      // ── Section titles — fire on scroll (water-emerge from baseline) ──
      document
        .querySelectorAll<HTMLElement>(".section-title-anim")
        .forEach((el) => {
          const split = new SplitText(el, { type: "lines" });
          wrapLines(split.lines);
          gsap.from(split.lines, {
            scrollTrigger: {
              trigger: el,
              start: "top 88%",
            },
            y: "115%",
            stagger: 0.1,
            duration: 1,
            ease: "power4.out",
          });
        });

      // ── "Trabajemos." — emerge entrance + letter-by-letter scrub ──
      const trabajemosEl =
        document.querySelector<HTMLElement>(".trabajemos-anim");
      if (trabajemosEl) {
        // One split for both effects: lines drive the emerge, chars the scrub.
        const tSplit = new SplitText(trabajemosEl, { type: "lines,chars" });
        wrapLines(tSplit.lines);

        // Entrance — emerge from the baseline like the other section titles.
        gsap.from(tSplit.lines, {
          scrollTrigger: { trigger: trabajemosEl, start: "top 88%" },
          y: "115%",
          stagger: 0.1,
          duration: 1,
          ease: "power4.out",
        });

        // Scrubbed reveal — letters illuminate from #contact to the page bottom.
        gsap.set(tSplit.chars, { opacity: 0.08 });
        const tTl = gsap.timeline({
          scrollTrigger: {
            trigger: "#contact",
            start: "top 60%",
            endTrigger: "footer",
            end: "bottom bottom",
            scrub: 1.5,
            invalidateOnRefresh: true,
          },
        });
        tSplit.chars.forEach((char, i) => {
          tTl.to(
            char,
            { opacity: 1, ease: "power1.inOut", duration: 1 },
            i * 0.18,
          );
        });
      }

      // Fonts change text metrics after load → recompute every ScrollTrigger
      // once the final layout is known (also covers the intro-skipped path).
      document.fonts?.ready.then(() => ScrollTrigger.refresh());
      window.addEventListener("load", () => ScrollTrigger.refresh());

      // Lazy-loaded images below the fold grow the page as the user scrolls,
      // which would otherwise leave scroll-driven triggers (e.g. "Trabajemos.")
      // mapped to stale positions computed against a shorter page. Refresh
      // whenever the document height changes (debounced).
      let refreshTimer: ReturnType<typeof setTimeout>;
      const sizeObserver = new ResizeObserver(() => {
        clearTimeout(refreshTimer);
        refreshTimer = setTimeout(() => ScrollTrigger.refresh(), 150);
      });
      sizeObserver.observe(document.body);

      // Persist the scroll position so the next load can gate the intro on it
      // (we manage restoration manually — see the inline head script).
      const saveScrollY = () => {
        try {
          sessionStorage.setItem("__scrollY", String(window.scrollY));
        } catch (_e) {}
      };
      window.addEventListener("pagehide", saveScrollY);
      document.addEventListener("visibilitychange", () => {
        if (document.visibilityState === "hidden") saveScrollY();
      });
    </script>
  </body>
</html>
