---
// ═══════════════════════════════════════════════════════════
//  Layout.astro — SEO-optimised base layout with native i18n
//  Kevin Gómez Lázaro · Full Stack Developer · Lima, Perú
// ═══════════════════════════════════════════════════════════
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const locale = (Astro.currentLocale || "es") as "es" | "en";
const isEn = locale === "en";

const siteURL = "https://kevin-gomez.dev";
const canonicalURL = isEn ? `${siteURL}/en/` : `${siteURL}/`;

const {
  title = isEn
    ? "Kevin Gómez | Full Stack Developer Lima, Peru — Next.js · React · NestJS"
    : "Kevin Gómez | Full Stack Developer Lima, Perú — Next.js · React · NestJS",
  description = isEn
    ? "Full Stack Developer with 8+ years of experience in Lima, Peru. Specialist in Next.js, React, NestJS, Headless WordPress, Laravel and E-Commerce. Projects for Entel, NERD, Well-Done. Available for freelance."
    : "Full Stack Developer con 8+ años de experiencia en Lima, Perú. Especialista en Next.js, React, NestJS, WordPress Headless, Laravel y E-Commerce. Proyectos para Entel, NERD, Well-Done. Disponible para freelance.",
  ogImage = `${siteURL}/og-image.jpg`,
} = Astro.props;

const keywords = isEn
  ? "full stack developer lima peru, web developer peru, next.js developer peru, react developer lima, nestjs developer, headless wordpress, laravel developer peru, ecommerce developer, freelance developer peru, kevin gomez"
  : "full stack developer lima peru, desarrollador web lima, next.js developer peru, react developer lima, nestjs developer, wordpress headless, laravel developer peru, ecommerce developer, desarrollador freelance lima, kevin gomez";

// ─── JSON-LD Structured Data ───
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteURL}/#person`,
      name: "Kevin Gómez Lázaro",
      givenName: "Kevin",
      familyName: "Gómez Lázaro",
      jobTitle: "Full Stack Developer",
      description:
        "Full Stack Developer con 8+ años de experiencia en Lima, Perú. Especialista en Next.js, React, NestJS, WordPress Headless, Laravel y soluciones e-commerce.",
      url: siteURL,
      email: "kevin94897@gmail.com",
      telephone: "+51947841355",
      image: ogImage,
      address: {
        "@type": "PostalAddress",
        addressLocality: "Lima",
        addressRegion: "Lima",
        addressCountry: "PE",
      },
      sameAs: ["https://github.com/kevin94897/"],
      knowsAbout: [
        "Next.js",
        "React",
        "NestJS",
        "WordPress Headless",
        "Laravel",
        "Node.js",
        "Astro",
        "PHP",
        "TypeScript",
        "SEO Técnico",
        "E-Commerce",
        "Shopify",
        "WooCommerce",
      ],
      hasCredential: [
        {
          "@type": "EducationalOccupationalCredential",
          name: "Ingeniería de Sistemas — Bachiller",
          recognizedBy: {
            "@type": "Organization",
            name: "Universidad Nacional del Callao",
          },
        },
        {
          "@type": "EducationalOccupationalCredential",
          name: "Scrum Foundation Professional Certificate (SFPC)",
          description: "Score: 95/100",
        },
      ],
    },
    {
      "@type": "ProfessionalService",
      "@id": `${siteURL}/#service`,
      name: "Kevin Gómez — Full Stack Developer & Web Agency",
      description:
        "Servicios de desarrollo web Full Stack, e-commerce, SEO técnico y diseño UX en Lima, Perú. Disponible para proyectos freelance y colaboraciones remotas.",
      url: siteURL,
      provider: { "@id": `${siteURL}/#person` },
      areaServed: [
        { "@type": "City", name: "Lima" },
        { "@type": "Country", name: "Perú" },
        { "@type": "AdministrativeArea", name: "América Latina" },
      ],
      priceRange: "S/. 850 – S/. 1,650",
      hasOfferCatalog: {
        "@type": "OfferCatalog",
        name: "Planes de Desarrollo Web",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Sitio Web Básico" },
            price: "850",
            priceCurrency: "PEN",
          },
          {
            "@type": "Offer",
            itemOffered: { "@type": "Service", name: "Sitio Corporativo" },
            price: "1200",
            priceCurrency: "PEN",
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Tienda Virtual E-Commerce",
            },
            price: "1650",
            priceCurrency: "PEN",
          },
        ],
      },
    },
    {
      "@type": "WebSite",
      "@id": `${siteURL}/#website`,
      url: siteURL,
      name: "Kevin Gómez — Full Stack Developer",
      description:
        "Portfolio profesional de Kevin Gómez Lázaro, Full Stack Developer en Lima, Perú.",
      inLanguage: ["es-PE", "en"],
      author: { "@id": `${siteURL}/#person` },
    },
  ],
};
---

<!doctype html>
<html lang={locale} dir="ltr">
  <head>
    <!-- ─── Charset & Viewport ─── -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ─── Primary SEO ─── -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Kevin Gómez Lázaro" />
    <meta
      name="robots"
      content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />
    <meta name="theme-color" content="#b4df00" />

    <!-- ─── Canonical ─── -->
    <link rel="canonical" href={canonicalURL} />

    <!-- ─── Open Graph ─── -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta
      property="og:site_name"
      content="Kevin Gómez — Full Stack Developer"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Kevin Gómez — Full Stack Developer Lima, Perú"
    />
    <meta property="og:locale" content={isEn ? "en_US" : "es_PE"} />
    <meta property="og:locale:alternate" content={isEn ? "es_PE" : "en_US"} />

    <!-- ─── Twitter Card ─── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta
      name="twitter:image:alt"
      content="Kevin Gómez — Full Stack Developer"
    />

    <!-- ─── Geo / Local SEO ─── -->
    <meta name="geo.region" content="PE-LIM" />
    <meta name="geo.placename" content="Lima, Perú" />
    <meta name="language" content={isEn ? "English" : "Spanish"} />
    <meta name="revisit-after" content="7 days" />

    <!-- ─── hreflang — alternate language URLs ─── -->
    <link rel="alternate" hreflang="es" href={`${siteURL}/`} />
    <link rel="alternate" hreflang="en" href={`${siteURL}/en/`} />
    <link rel="alternate" hreflang="x-default" href={`${siteURL}/`} />

    <!-- ─── Fonts: self-hosted woff2 — preloaded, zero external requests ─── -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- ─── Icons: Phosphor — async (non-render-blocking) ─── -->
    <link
      rel="stylesheet"
      href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css"
      media="print"
    />
    <link
      rel="stylesheet"
      href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/bold/style.css"
      media="print"
    />
    <noscript>
      <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css" />
      <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/bold/style.css" />
    </noscript>
    <!-- Switch media to 'all' after load so icons/fonts apply without blocking -->
    <script is:inline>
      document.querySelectorAll('link[media="print"]').forEach(function(l){
        l.addEventListener('load', function(){ l.media = 'all'; });
        if(l.sheet) l.media = 'all';
      });
    </script>

    <!-- ─── Favicon ─── -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- ─── Sitemap ─── -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- ─── Structured Data (JSON-LD) ─── -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData, null, 2)}
    />

    <!-- ─── Intro preloader: lock scroll early + JS-fail safety net ─── -->
    <noscript><style>{`#preloader{display:none!important}`}</style></noscript>
    <script is:inline>
      try {
        // Landing on an inner section via anchor (e.g. /#contact) → no intro.
        // (Scroll isn't locked here so the browser can restore scroll position;
        //  the module reads scrollY to decide whether to play the intro.)
        var h = location.hash;
        var toSection =
          h && h.length > 1 && h !== "#hero" && h !== "#main-content";
        if (toSection) {
          window.__skipIntro = true;
          var st = document.createElement("style");
          st.textContent = "#preloader{display:none!important}";
          document.head.appendChild(st);
        }
      } catch (e) {}
      // If the animation module never runs (or fails after hiding the title),
      // force-reveal after 6s so the page is never stuck invisible.
      window.__introFallback = setTimeout(function () {
        var p = document.getElementById("preloader");
        if (p) p.style.display = "none";
        var ht = document.querySelector(".hero-title-anim");
        if (ht) { ht.style.opacity = "1"; ht.style.visibility = "visible"; }
        document.documentElement.style.overflow = "";
      }, 6000);
    </script>
  </head>

  <body>
    <!-- ─── Intro: black backdrop; the hero <h1> itself animates over it ─── -->
    <div id="preloader" aria-hidden="true"></div>

    <!-- Accessibility: skip to main content -->
    <a href="#main-content" class="skip-link"
      >{isEn ? "Skip to main content" : "Saltar al contenido principal"}</a
    >

    <slot />

    <!-- GSAP title animations -->
    <script>
      import Lenis from "lenis";
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import { SplitText } from "gsap/SplitText";

      gsap.registerPlugin(ScrollTrigger, SplitText);

      // ── Lenis smooth scroll ─────────────────────────────────
      const BASE_LERP = 0.09; // interpolation — lower = smoother/slower
      const BASE_WHEEL = 0.85;
      // Near the bottom the scroll eases into a slower, smoother glide.
      const SLOW_LERP = 0.045;
      const SLOW_WHEEL = 0.5;
      const SLOW_FROM = 0.82; // progress (0–1) where the slowdown begins

      const lenis = new Lenis({
        lerp: BASE_LERP,
        smoothWheel: true,
        wheelMultiplier: BASE_WHEEL,
        touchMultiplier: 1.5,
        syncTouch: false, // mobile uses native scroll
      });

      // Keep GSAP ScrollTrigger in sync with Lenis + slow down near the end.
      lenis.on("scroll", (e: any) => {
        ScrollTrigger.update();
        const progress: number =
          (e && typeof e.progress === "number" ? e.progress : lenis.progress) ||
          0;
        if (progress >= SLOW_FROM) {
          const t = (progress - SLOW_FROM) / (1 - SLOW_FROM); // 0 → 1
          const eased = t * t * (3 - 2 * t); // smoothstep
          (lenis as any).options.lerp = BASE_LERP - (BASE_LERP - SLOW_LERP) * eased;
          (lenis as any).options.wheelMultiplier =
            BASE_WHEEL - (BASE_WHEEL - SLOW_WHEEL) * eased;
        } else {
          (lenis as any).options.lerp = BASE_LERP;
          (lenis as any).options.wheelMultiplier = BASE_WHEEL;
        }
      });
      gsap.ticker.add((time) => lenis.raf(time * 1000));
      gsap.ticker.lagSmoothing(0);

      // Allow other components to pause/resume Lenis (e.g. scroll-hijack sections)
      document.addEventListener("lenis:stop", () => lenis.stop());
      document.addEventListener("lenis:start", () => lenis.start());

      function wrapLines(lines: Element[]) {
        lines.forEach((line) => {
          const wrap = document.createElement("div");
          wrap.style.overflow = "hidden";
          wrap.style.display = "block";
          // Extra space below the clip boundary so descenders (y, j, g, p…)
          // are not cut off. Negative margin keeps the overall layout spacing.
          wrap.style.paddingBottom = "0.25em";
          wrap.style.marginBottom = "-0.25em";
          line.parentNode!.insertBefore(wrap, line);
          wrap.appendChild(line);
        });
      }

      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      const heroTitle = document.querySelector<HTMLElement>(".hero-title-anim");
      // Hide the hero title until the intro takes over, so it never flashes
      // in its final spot before the entrance animation runs.
      if (heroTitle) gsap.set(heroTitle, { autoAlpha: 0 });

      // ── Hero title fallback reveal (used when the intro is skipped) ──
      function animateHeroTitle() {
        if (!heroTitle) return;
        gsap.set(heroTitle, { autoAlpha: 1 });
        const split = new SplitText(heroTitle, { type: "lines" });
        wrapLines(split.lines);
        gsap.from(split.lines, {
          y: "115%",
          stagger: 0.1,
          duration: 1.15,
          delay: 0.2,
          ease: "power4.out",
        });
      }

      // ── Hero sub-elements — ordered reveal (tech → roles → secondary) ──
      function animateHeroExtras() {
        const allHeroEls =
          document.querySelectorAll<HTMLElement>("[data-hero-reveal]");
        const techEl = document.querySelector<HTMLElement>(
          '[data-hero-reveal="tech"]',
        );
        const rolesEl = document.querySelector<HTMLElement>(
          '[data-hero-reveal="roles"]',
        );
        const secondaryEls = document.querySelectorAll<HTMLElement>(
          '[data-hero-reveal="secondary"]',
        );

        if (!allHeroEls.length) return;
        gsap.set(allHeroEls, { opacity: 0, y: 18 });

        const tl = gsap.timeline();
        if (techEl)
          tl.to(techEl, { opacity: 1, y: 0, duration: 0.6, ease: "power2.out" }, 0);
        if (rolesEl)
          tl.to(rolesEl, { opacity: 1, y: 0, duration: 0.6, ease: "power2.out" }, 0.22);
        if (secondaryEls.length)
          tl.to(
            secondaryEls,
            { opacity: 1, y: 0, stagger: 0.12, duration: 0.55, ease: "power2.out" },
            0.44,
          );
        tl.call(
          () => document.dispatchEvent(new CustomEvent("hero:reveal-spline")),
          undefined,
          0.85,
        );
      }

      // ── Intro entrance — name brightens 0→100, then flows to its place ──
      clearTimeout((window as any).__introFallback);
      const preloader = document.getElementById("preloader");

      function unlockScroll() {
        document.documentElement.style.overflow = "";
        lenis.start();
      }

      function hidePreloader() {
        if (preloader) gsap.set(preloader, { display: "none" });
      }

      const mainName = heroTitle?.querySelector<HTMLElement>(".hero-name-main");
      const suffixName =
        heroTitle?.querySelector<HTMLElement>(".hero-name-suffix");

      // Only play the intro when landing at the very top (hero in view).
      // If the page is reloaded/opened scrolled into another section, skip it.
      const atTop =
        !(window as any).__skipIntro && window.scrollY < 4;

      if (!preloader || !heroTitle || !mainName || prefersReduced || !atTop) {
        // Skip the cinematic entrance: reduced motion, missing nodes, or
        // the user isn't at the top of the page.
        hidePreloader();
        unlockScroll();
        animateHeroTitle();
        animateHeroExtras();
      } else {
        document.documentElement.style.overflow = "hidden";
        lenis.stop();

        // Declared outside try so the catch block can clean it up if needed.
        let heroPlaceholder: HTMLDivElement | null = null;

        try {
          // 1 — Measure in natural DOM position, then reparent to <body> so
          //     z-index:100001 lives in the root stacking context (above #preloader
          //     at z:100000). The parent div has z-index:10 which would otherwise
          //     cap the effective z-index to 10.
          const rect = heroTitle.getBoundingClientRect();
          // Measure the actual rendered text width (not the full h1 box) so we
          // can center the VISIBLE name on screen rather than the container box.
          const textWidth = mainName.offsetWidth;

          // Insert a same-sized invisible placeholder so the flex siblings
          // (tech bar, role cycling) keep their position while the <h1> is
          // animated at body level. replaceWith/replaceWith are synchronous so
          // the browser sees a single layout change with no visual jump.
          heroPlaceholder = document.createElement("div");
          heroPlaceholder.style.cssText = `width:${rect.width}px;height:${rect.height}px;visibility:hidden;flex-shrink:0;`;
          heroTitle.replaceWith(heroPlaceholder);
          document.body.appendChild(heroTitle);

          gsap.set(heroTitle, {
            position: "fixed",
            top: rect.top,
            left: rect.left,
            width: rect.width,
            margin: 0,
            zIndex: 100001,
            autoAlpha: 1,
            transformOrigin: "center center",
          });
          // Shift so the visible text (not the full-width h1 box) is centered.
          const initialX = window.innerWidth / 2 - textWidth / 2 - rect.left;
          const dy = window.innerHeight / 2 - (rect.top + rect.height / 2);
          gsap.set(heroTitle, { x: initialX, y: dy, scale: 1.12 });

          // 2 — Hide the ".ケビン" suffix and split the name into letters,
          //     each starting dim. K = first (0%), z = last (100%).
          if (suffixName) gsap.set(suffixName, { autoAlpha: 0 });
          const split = new SplitText(mainName, { type: "chars", charsClass: "char" });
          gsap.set(split.chars, { opacity: 0.3 });

          const intro = gsap.timeline();
          intro
            // Letters brighten left→right, slow and always fully visible.
            .to(split.chars, {
              opacity: 1,
              duration: 0.55,
              ease: "power1.out",
              stagger: { each: 0.22 },
            })
            .addLabel("flow", "+=0.45")
            // 3 — The name flows back to its real position (transforms → 0).
            .to(
              heroTitle,
              { x: 0, y: 0, scale: 1, duration: 1.4, ease: "power3.inOut" },
              "flow",
            )
            // Black backdrop fades, revealing the page behind the moving name.
            .to(
              preloader,
              { autoAlpha: 0, duration: 1, ease: "power2.inOut" },
              "flow+=0.15",
            )
            // The ".ケビン" suffix fades in as the name settles.
            .to(
              suffixName,
              { autoAlpha: 1, duration: 0.7, ease: "power2.out" },
              "flow+=0.7",
            )
            // Hand over: unlock scroll + reveal the rest of the hero.
            .add(() => {
              unlockScroll();
              animateHeroExtras();
            }, "flow+=0.35")
            // Cleanup: atomically swap placeholder → <h1> back in one frame,
            // then clear GSAP inline styles so the <h1> returns to normal flow
            // with no layout jump.
            .add(() => {
              split.revert();
              heroPlaceholder!.replaceWith(heroTitle);
              gsap.set(heroTitle, {
                clearProps: "position,top,left,width,margin,zIndex,transform,opacity,visibility",
              });
              hidePreloader();
            });
        } catch (_err) {
          // Restore <h1> to the hero section if the placeholder swap already ran.
          if (heroPlaceholder?.isConnected) heroPlaceholder.replaceWith(heroTitle);
          gsap.set(heroTitle, { clearProps: "all" });
          hidePreloader();
          unlockScroll();
          animateHeroTitle();
          animateHeroExtras();
        }
      }

      // ── Section titles — fire on scroll (water-emerge from baseline) ──
      document
        .querySelectorAll<HTMLElement>(".section-title-anim")
        .forEach((el) => {
          const split = new SplitText(el, { type: "lines" });
          wrapLines(split.lines);
          gsap.from(split.lines, {
            scrollTrigger: {
              trigger: el,
              start: "top 88%",
            },
            y: "115%",
            stagger: 0.1,
            duration: 1,
            ease: "power4.out",
          });
        });

      // ── "Trabajemos." — letter-by-letter scrubbed reveal ──────────
      // Tied to scroll position so Lenis's bottom-slowdown makes it
      // naturally decelerate as the letters finish brightening.
      const trabajemosEl =
        document.querySelector<HTMLElement>(".trabajemos-anim");
      if (trabajemosEl) {
        const tSplit = new SplitText(trabajemosEl, { type: "chars" });
        gsap.set(tSplit.chars, { opacity: 0.08 });
        const tTl = gsap.timeline({
          scrollTrigger: {
            trigger: trabajemosEl,
            start: "top 90%",
            end: "top 20%",
            scrub: 1.8,
          },
        });
        tSplit.chars.forEach((char, i) => {
          tTl.to(
            char,
            { opacity: 1, ease: "power1.inOut", duration: 1 },
            i * 0.18,
          );
        });
      }
    </script>
  </body>
</html>
