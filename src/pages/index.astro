---
// ═══════════════════════════════════════════════════════════
//  index.astro — Main page
//  Assembles all sections + client-side scripts
// ═══════════════════════════════════════════════════════════
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Services from "../components/Services.astro";
import Experience from "../components/Experience.astro";
import Projects from "../components/Projects.astro";
import SkillsBars from "../components/SkillsBars.astro";
import Testimonials from "../components/Testimonials.astro";
import Workflow from "../components/Workflow.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import Marquee from "../components/Marquee.astro";
---

<Layout>
  <!-- Custom cursor -->
  <div id="cursor" aria-hidden="true"></div>
  <div id="cursor-ring" aria-hidden="true"></div>

  <!-- Circuit background (scroll-driven PCB animation) -->
  <!-- <CircuitBackground /> -->

  <!-- Lang-switch loader: thin bar + page flash -->
  <div id="lang-loader" aria-hidden="true">
    <div id="lang-bar"></div>
  </div>

  <!-- Navigation -->
  <Nav />

  <!-- Main content -->
  <main id="main-content">
    <Hero />
    <Marquee
      items={[
        "Astro JS",
        "React & Next.js",
        "Node.js & NestJS",
        "TypeScript",
        "E-Commerce",
        "IA",
      ]}
    />
    <About />
    <Services />
    <Experience />
    <Projects />
    <SkillsBars />
    <Testimonials />
    <Workflow />
    <!-- <Pricing /> -->
    <Contact />
  </main>

  <Footer />
</Layout>

<!-- ═══════════════════════════════════════════════════════════
     CLIENT-SIDE SCRIPTS
     All deferred — run after page is interactive
     ═══════════════════════════════════════════════════════════ -->
<script>
  // El idioma ahora se determina nativamente por Astro y se expone en la etiqueta HTML
  const currentLang = document.documentElement.lang || "es";

  /* ──────────────────────────────────────────────────────────
   CUSTOM CURSOR
────────────────────────────────────────────────────────── */
  const cursor = document.getElementById("cursor")!;
  const ring = document.getElementById("cursor-ring")!;
  let mx = 0,
    my = 0,
    rx = 0,
    ry = 0;

  document.addEventListener("mousemove", (e) => {
    mx = e.clientX;
    my = e.clientY;
    cursor.style.left = mx + "px";
    cursor.style.top = my + "px";
  });

  (function animRing() {
    rx += (mx - rx) * 0.1;
    ry += (my - ry) * 0.1;
    ring.style.left = rx + "px";
    ring.style.top = ry + "px";
    requestAnimationFrame(animRing);
  })();

  /* ──────────────────────────────────────────────────────────
   PARTICLES CANVAS
────────────────────────────────────────────────────────── */
  const canvas = document.getElementById("particles") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;
  let W: number, H: number;

  function resizeCanvas() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  resizeCanvas();
  window.addEventListener("resize", resizeCanvas, { passive: true });

  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    r: number;
    o: number;
  }
  const pts: Particle[] = Array.from({ length: 55 }, () => ({
    x: Math.random() * 1920,
    y: Math.random() * 1080,
    vx: (Math.random() - 0.5) * 0.28,
    vy: (Math.random() - 0.5) * 0.28,
    r: Math.random() * 1.4 + 0.4,
    o: Math.random() * 0.5 + 0.1,
  }));

  (function drawPts() {
    ctx.clearRect(0, 0, W, H);
    pts.forEach((p) => {
      p.x += p.vx;
      p.y += p.vy;
      if (p.x < 0 || p.x > W) p.vx *= -1;
      if (p.y < 0 || p.y > H) p.vy *= -1;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(180,223,0,${p.o})`;
      ctx.fill();
    });
    for (let i = 0; i < pts.length; i++) {
      for (let j = i + 1; j < pts.length; j++) {
        const dx = pts[i].x - pts[j].x;
        const dy = pts[i].y - pts[j].y;
        const d = Math.sqrt(dx * dx + dy * dy);
        if (d < 110) {
          ctx.beginPath();
          ctx.moveTo(pts[i].x, pts[i].y);
          ctx.lineTo(pts[j].x, pts[j].y);
          ctx.strokeStyle = `rgba(180,223,0,${0.07 * (1 - d / 110)})`;
          ctx.lineWidth = 0.5;
          ctx.stroke();
        }
      }
    }
    requestAnimationFrame(drawPts);
  })();

  /* ──────────────────────────────────────────────────────────
   INTERSECTION OBSERVER — REVEAL ANIMATIONS
────────────────────────────────────────────────────────── */
  const revealEls = document.querySelectorAll(".reveal, .reveal-left, .reveal-right");

  const io = new IntersectionObserver(
    (entries) =>
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("visible");
          io.unobserve(e.target);
        }
      }),
    { threshold: 0.04 },
  );
  revealEls.forEach((el) => io.observe(el));

  // Safari iOS: elements already in viewport at load may not fire the observer.
  // Force-reveal any element whose top is within the initial viewport.
  const forceRevealInViewport = () => {
    const vh = window.innerHeight;
    revealEls.forEach((el) => {
      if (!el.classList.contains("visible")) {
        const rect = el.getBoundingClientRect();
        if (rect.top < vh && rect.bottom > 0) {
          el.classList.add("visible");
          io.unobserve(el);
        }
      }
    });
  };
  // Run immediately and again after a short delay for Safari's deferred layout
  forceRevealInViewport();
  setTimeout(forceRevealInViewport, 400);

  // Skill pills stagger
  const skillsGridEl = document.querySelector(".skills-grid");
  if (skillsGridEl) {
    const sio = new IntersectionObserver(
      (entries) =>
        entries.forEach((e) => {
          if (e.isIntersecting) {
            document
              .querySelectorAll(".skill-pill")
              .forEach((p, i) =>
                setTimeout(() => p.classList.add("visible"), i * 40),
              );
          }
        }),
      { threshold: 0.2 },
    );
    sio.observe(skillsGridEl);
  }

  // Skill bars fill
  const sbg = document.querySelector(".skills-bars-grid");
  if (sbg) {
    const barsIO = new IntersectionObserver(
      (entries) =>
        entries.forEach((e) => {
          if (e.isIntersecting) {
            document
              .querySelectorAll<HTMLElement>(".skill-bar-fill")
              .forEach((b) => {
                b.style.width = (b.dataset.pct ?? "0") + "%";
              });
          }
        }),
      { threshold: 0.2 },
    );
    barsIO.observe(sbg);
  }

  /* ──────────────────────────────────────────────────────────
   HERO ROLE CYCLING
────────────────────────────────────────────────────────── */
  const roles = document.querySelectorAll(".hero-role");
  let ri = 0;
  setInterval(() => {
    roles[ri].classList.remove("active");
    ri = (ri + 1) % roles.length;
    roles[ri].classList.add("active");
  }, 2600);

  /* ──────────────────────────────────────────────────────────
   EMBLA — TESTIMONIALS CAROUSEL
────────────────────────────────────────────────────────── */
  const tViewport = document.getElementById("emblaTestimonials")!;
  const { default: EmblaCarousel } = await import("embla-carousel");
  const { default: EmblaCarouselAutoplay } = await import("embla-carousel-autoplay");
  const tAutoplay = EmblaCarouselAutoplay({
    delay: 5500,
    stopOnInteraction: true,
  });
  const emblaT = EmblaCarousel(
    tViewport,
    { loop: true, align: "start", slidesToScroll: 1 },
    [tAutoplay],
  );

  const tDotsEl = document.getElementById("emblaTDots")!;

  // ── Dot helpers ───────────────────────────────────────────
  function buildDots(container: HTMLElement, embla: any) {
    const count = embla.scrollSnapList().length;
    container.innerHTML = "";
    for (let i = 0; i < count; i++) {
      const btn = document.createElement("button");
      btn.className =
        "w-2 h-2 rounded-full border border-white/20 bg-transparent transition-all duration-300 cursor-none";
      btn.setAttribute("aria-label", `Testimonio ${i + 1}`);
      btn.setAttribute("role", "tab");
      btn.addEventListener("click", () => embla.scrollTo(i));
      container.appendChild(btn);
    }
    updateDots(container, embla);
  }

  function updateDots(container: HTMLElement, embla: any) {
    const idx = embla.selectedScrollSnap();
    Array.from(container.children).forEach((dot, i) => {
      const el = dot as HTMLElement;
      const active = i === idx;
      el.style.background = active ? "var(--lime)" : "";
      el.style.borderColor = active ? "var(--lime)" : "";
      el.style.width = active ? "20px" : "";
    });
  }

  function updateActiveCard() {
    document
      .querySelectorAll(".testimonial-card")
      .forEach((c, i) =>
        c.classList.toggle("is-selected", i === emblaT.selectedScrollSnap()),
      );
  }

  buildDots(tDotsEl, emblaT);
  emblaT.on("select", () => {
    updateDots(tDotsEl, emblaT);
    updateActiveCard();
  });
  emblaT.on("init", () => {
    updateDots(tDotsEl, emblaT);
    updateActiveCard();
  });

  document
    .getElementById("tPrev")!
    .addEventListener("click", () => emblaT.scrollPrev());
  document
    .getElementById("tNext")!
    .addEventListener("click", () => emblaT.scrollNext());

  /* ──────────────────────────────────────────────────────────
   CONTACT FORM — real validation + SMTP send
  ────────────────────────────────────────────────────────── */
  (function initContactForm() {
    const form = document.getElementById(
      "contactForm",
    ) as HTMLFormElement | null;
    const submitBtn = document.getElementById(
      "submitBtn",
    ) as HTMLButtonElement | null;
    const submitIcon = document.getElementById(
      "submitIcon",
    ) as HTMLElement | null;
    const submitLabel = document.getElementById(
      "submitLabel",
    ) as HTMLElement | null;
    const toast = document.getElementById("formToast") as HTMLElement | null;
    const toastMsg = document.getElementById(
      "formToastMsg",
    ) as HTMLElement | null;
    const toastIcon = document.getElementById(
      "formToastIcon",
    ) as HTMLElement | null;

    if (!form || !submitBtn) return;

    // ── Validation rules ─────────────────────────────────────
    interface Rule {
      id: string;
      test: (v: string) => boolean;
      msgES: string;
      msgEN: string;
    }

    const rules: Rule[] = [
      {
        id: "fname",
        test: (v) => v.trim().length > 0,
        msgES: "El nombre es requerido.",
        msgEN: "First name is required.",
      },
      {
        id: "lname",
        test: (v) => v.trim().length > 0,
        msgES: "El apellido es requerido.",
        msgEN: "Last name is required.",
      },
      {
        id: "email",
        test: (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()),
        msgES: "Email inválido.",
        msgEN: "Invalid email address.",
      },
      {
        id: "subject",
        test: (v) => v.trim().length > 0,
        msgES: "El asunto es requerido.",
        msgEN: "Subject is required.",
      },
      {
        id: "message",
        test: (v) => v.trim().length >= 10,
        msgES: "Mínimo 10 caracteres.",
        msgEN: "Minimum 10 characters.",
      },
    ];

    function getErrorMsg(rule: Rule): string {
      return currentLang === "en" ? rule.msgEN : rule.msgES;
    }

    function validateField(rule: Rule): boolean {
      const el = document.getElementById(rule.id) as
        | HTMLInputElement
        | HTMLTextAreaElement
        | null;
      const errEl = el
        ?.closest(".field-group")
        ?.querySelector(".field-error") as HTMLElement | null;
      if (!el) return true;

      const ok = rule.test(el.value);
      el.classList.toggle("is-invalid", !ok);
      el.classList.toggle("is-valid", ok);
      if (errEl) errEl.textContent = ok ? "" : getErrorMsg(rule);
      return ok;
    }

    function validateAll(): boolean {
      return rules.map(validateField).every(Boolean);
    }

    // ── Per-field blur validation ─────────────────────────────
    rules.forEach((rule) => {
      const el = document.getElementById(rule.id);
      el?.addEventListener("blur", () => validateField(rule));
      el?.addEventListener("input", () => {
        // re-validate only if already marked
        if (
          el.classList.contains("is-invalid") ||
          el.classList.contains("is-valid")
        ) {
          validateField(rule);
        }
      });
    });

    // ── Toast helper ─────────────────────────────────────────
    let toastTimer: ReturnType<typeof setTimeout>;
    function showToast(type: "success" | "error", msg: string) {
      if (!toast || !toastMsg || !toastIcon) return;
      clearTimeout(toastTimer);
      toast.className = `mb-5 flex items-center gap-3 px-4 py-3 rounded-[10px] border text-[13px] toast-${type}`;
      toastMsg.textContent = msg;
      toastIcon.className = `ph ${type === "success" ? "ph-check-circle" : "ph-warning"} text-[18px]`;
      if (type === "success") {
        toastTimer = setTimeout(() => toast.classList.add("hidden"), 7000);
      }
    }

    // ── Loading state ─────────────────────────────────────────
    function setLoading(on: boolean) {
      submitBtn!.disabled = on;
      if (on) {
        if (submitIcon) {
          submitIcon.className = "spin";
          submitIcon.textContent = "⟳";
        }
        if (submitLabel)
          submitLabel.textContent =
            currentLang === "en" ? "Sending…" : "Enviando…";
      } else {
        if (submitIcon) {
          submitIcon.className = "ph ph-paper-plane-tilt";
          submitIcon.textContent = "";
        }
        if (submitLabel)
          submitLabel.textContent = currentLang === "en" ? "Send Message" : "Enviar Mensaje";
      }
    }

    // ── Form submit → Brevo via hidden iframe ─────────────────
    const brevoFrame = document.getElementById(
      "brevo_frame",
    ) as HTMLIFrameElement | null;

    form.addEventListener("submit", (e) => {
      if (!validateAll()) {
        e.preventDefault();
        const firstInvalid = form.querySelector(
          ".is-invalid",
        ) as HTMLElement | null;
        firstInvalid?.scrollIntoView({ behavior: "smooth", block: "center" });
        return;
      }

      // Validation passed — let the form POST natively to Brevo iframe
      setLoading(true);

      if (brevoFrame) {
        brevoFrame.addEventListener(
          "load",
          () => {
            setLoading(false);
            showToast(
              "success",
              currentLang === "en"
                ? "✓ Message sent! I'll reply within 24 hours."
                : "✓ ¡Mensaje enviado! Te responderé en menos de 24 horas.",
            );
            form.reset();
            form.querySelectorAll(".form-input").forEach((el) => {
              el.classList.remove("is-valid", "is-invalid");
            });
            form.querySelectorAll(".field-error").forEach((el) => {
              (el as HTMLElement).textContent = "";
            });
          },
          { once: true },
        );
      }
    });
  })();


</script>
