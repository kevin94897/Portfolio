---
import { useTranslations } from '../i18n/utils';

const locale = (Astro.currentLocale || 'es') as 'es' | 'en';
const t = useTranslations(locale);

const steps = [
  {
    num: "01",
    icon: "ph-handshake",
    titleKey: "wf.s1.title",
    descKey: "wf.s1.desc",
  },
  {
    num: "02",
    icon: "ph-figma-logo",
    titleKey: "wf.s2.title",
    descKey: "wf.s2.desc",
  },
  {
    num: "03",
    icon: "ph-code",
    titleKey: "wf.s3.title",
    descKey: "wf.s3.desc",
  },
  {
    num: "04",
    icon: "ph-rocket-launch",
    titleKey: "wf.s4.title",
    descKey: "wf.s4.desc",
  },
];
---

<section
  id="workflow"
  class="py-20 lg:py-[120px] bg-black"
  aria-labelledby="wf-heading"
>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-[60px]">
    <!-- Meta bar -->
    <div
      class="flex items-center justify-between border-b border-border pb-4 mb-12 lg:mb-16"
    >
      <p class="section-label !mb-0">
        <span>{t('wf.label')}</span>
        <span class="jp-tag">プロセス</span>
      </p>
      <span
        class="text-[9px] tracking-[0.22em] uppercase hidden md:block"
        style="color:rgba(255,255,255,0.18);">WORK PROCESS</span
      >
    </div>

    <!-- Two-column layout -->
    <div class="grid grid-cols-1 lg:grid-cols-[360px_1fr] gap-12 lg:gap-[80px]">
      <!-- Left: display text -->
      <div class="reveal-left">
        <h2
          id="wf-heading"
          class="section-title-anim font-display font-bold tracking-tightest leading-none text-white mb-4"
          style="font-size: clamp(2.8rem, 5.5vw, 5.5rem); font-optical-sizing: auto; font-variation-settings: 'opsz' 32;"
          set:html={t('wf.title')}
        >
        </h2>
        <p
          class="text-[13px] leading-[1.85] text-text/55 mb-10 lg:mb-12"
        >
          {t('wf.desc')}
        </p>

        <!-- Step icons -->
      </div>

      <!-- Right: accordion -->
      <div class="reveal-right" id="wf-accordion">
        {
          steps.map((step, i) => (
            <div class="wf-item border-t border-border">
              <button
                class="wf-trigger w-full flex items-center gap-5 lg:gap-6 py-[22px] lg:py-[26px] text-left group cursor-none"
                data-idx={String(i)}
                aria-expanded="false"
                aria-controls={`wf-panel-${i}`}
              >
                <span
                  class="text-[10px] tracking-[0.22em] font-syne flex-shrink-0"
                  style="color:rgba(255,255,255,0.25);width:28px;"
                >
                  {step.num}
                </span>
                <span
                  class="flex-1 font-syne text-[16px] lg:text-[19px] font-bold text-white group-hover:text-lime transition-colors duration-200"
                >
                  {t(step.titleKey as any)}
                </span>
                <i
                  class="wf-icon ph ph-plus text-[15px] text-muted/50 group-hover:text-lime flex-shrink-0 transition-[transform,color] duration-300"
                  aria-hidden="true"
                />
              </button>
              <div
                class="wf-panel overflow-hidden"
                id={`wf-panel-${i}`}
                style="height:0;transition:height 0.38s cubic-bezier(0.23,1,0.32,1);"
                role="region"
                aria-labelledby={`wf-trigger-${i}`}
              >
                <p
                  class="text-[13px] leading-[1.85] text-text/55 pb-6 lg:pb-8 pl-[48px] lg:pl-[52px]"
                >
                  {t(step.descKey as any)}
                </p>
              </div>
            </div>
          ))
        }
        <div class="border-t border-border" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-label {
    @apply text-[10px] tracking-[0.25em] text-lime uppercase flex items-center gap-3 mb-[14px];
  }
  .section-label::after {
    content: "";
    @apply block w-[40px] h-px bg-lime;
  }


  @media (min-width: 1024px) {
    .reveal-left {
      @apply opacity-0 -translate-x-[50px] transition-[opacity,transform] duration-[800ms] [transition-timing-function:cubic-bezier(0.23,1,0.32,1)];
    }
    .reveal-left.visible {
      @apply opacity-100 translate-x-0;
    }

    .reveal-right {
      @apply opacity-0 translate-x-[50px] transition-[opacity,transform] duration-[800ms] [transition-timing-function:cubic-bezier(0.23,1,0.32,1)];
    }
    .reveal-right.visible {
      @apply opacity-100 translate-x-0;
    }
  }

  /* Trigger hover: lime glow on icon */
  .wf-trigger[aria-expanded="true"] .wf-icon {
    transform: rotate(45deg);
    color: #b4df00;
  }
  .wf-trigger[aria-expanded="true"] > span:nth-child(2) {
    color: #b4df00;
  }
</style>

<script>
  // ── Reveal on scroll ──────────────────────────────────────
  const revealEls = document.querySelectorAll<HTMLElement>(
    "#workflow .reveal-left, #workflow .reveal-right",
  );
  const revealIO = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("visible");
          revealIO.unobserve(e.target);
        }
      });
    },
    { threshold: 0.04, rootMargin: "0px 0px -30px 0px" },
  );
  revealEls.forEach((el) => revealIO.observe(el));

  // ── Accordion ────────────────────────────────────────────
  const triggers = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".wf-trigger"),
  );

  let openIdx = -1;

  function closePanelAt(idx: number) {
    const t = triggers[idx];
    if (!t) return;
    const panel = document.getElementById(`wf-panel-${idx}`) as HTMLElement;
    t.setAttribute("aria-expanded", "false");
    panel.style.height = "0";
  }

  function openPanelAt(idx: number) {
    const t = triggers[idx];
    if (!t) return;
    const panel = document.getElementById(`wf-panel-${idx}`) as HTMLElement;
    t.setAttribute("aria-expanded", "true");
    panel.style.height = panel.scrollHeight + "px";
  }

  triggers.forEach((trigger, i) => {
    trigger.addEventListener("click", () => {
      const isOpen = openIdx === i;

      if (openIdx !== -1) closePanelAt(openIdx);

      if (isOpen) {
        openIdx = -1;
      } else {
        openPanelAt(i);
        openIdx = i;
      }
    });
  });
</script>
