---
// Contact.astro — Contact form + social links + CV download card
// Form uses Web3Forms (https://web3forms.com) — free, no backend needed.
// TODO: replace "YOUR_WEB3FORMS_ACCESS_KEY" below with the key from web3forms.com.
//       Sign up there with your personal email; all form submissions will arrive there.
import { useTranslations } from "../i18n/utils";

const locale = (Astro.currentLocale || "es") as "es" | "en";
const t = useTranslations(locale);
---

<section
  id="contact"
  class="py-20 lg:py-[120px] bg-black"
  aria-labelledby="contact-heading"
>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-[60px]">
    <p class="section-label">
      <span>{t("contact.label")}</span><span class="jp-tag">お問い合わせ</span>
    </p>
    <h2
      id="contact-heading"
      class="section-title-anim font-display font-bold tracking-tightest leading-none text-white mb-12"
      style="font-size: clamp(2.8rem, 5.5vw, 5.5rem); font-optical-sizing: auto; font-variation-settings: 'opsz' 32;"
    >
      Hablemos Hoy
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-6 lg:gap-[80px]">
      <!-- Left: socials + download -->
      <div class="reveal-left relative z-[2]">
        <p
          class="text-[13px] md:text-[14px] leading-[1.75] text-text/55 mb-5 lg:mb-7"
        >
          {t("contact.desc")}
        </p>

        <nav
          class="flex flex-col gap-[7px] mb-[18px] lg:mb-[22px]"
          aria-label="Redes y contacto"
        >
          <a
            href="tel:+51947841355"
            class="flex items-center gap-3 px-3 py-[10px] lg:px-4 lg:py-3 bg-surface border border-border text-text no-underline text-[12px] lg:text-[13px] transition-all duration-300 hover:border-lime/30 hover:translate-x-1 hover:text-lime hover:shadow-[0_0_18px_rgba(180,223,0,0.05)]"
          >
            <i class="ph ph-phone text-[17px] text-lime" aria-hidden="true"></i>
            +51 947 841 355
          </a>
          <!-- href and label set by JS — email never appears in static HTML -->
          <a
            href="#"
            id="email-contact-link"
            class="flex items-center gap-3 px-3 py-[10px] lg:px-4 lg:py-3 bg-surface border border-border text-text no-underline text-[12px] lg:text-[13px] transition-all duration-300 hover:border-lime/30 hover:translate-x-1 hover:text-lime hover:shadow-[0_0_18px_rgba(180,223,0,0.05)]"
          >
            <i class="ph ph-envelope text-[17px] text-lime" aria-hidden="true"
            ></i>
            <span id="email-contact-label">·····@·····</span>
          </a>
          <a
            href="https://kevin-gomez.dev"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 px-3 py-[10px] lg:px-4 lg:py-3 bg-surface border border-border text-text no-underline text-[12px] lg:text-[13px] transition-all duration-300 hover:border-lime/30 hover:translate-x-1 hover:text-lime hover:shadow-[0_0_18px_rgba(180,223,0,0.05)]"
          >
            <i class="ph ph-globe text-[17px] text-lime" aria-hidden="true"></i>
            kevin.grupo-gomez.com
          </a>
          <a
            href="https://github.com/kevin94897/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 px-3 py-[10px] lg:px-4 lg:py-3 bg-surface border border-border text-text no-underline text-[12px] lg:text-[13px] transition-all duration-300 hover:border-lime/30 hover:translate-x-1 hover:text-lime hover:shadow-[0_0_18px_rgba(180,223,0,0.05)]"
          >
            <i
              class="ph ph-github-logo text-[17px] text-lime"
              aria-hidden="true"></i>
            github.com/kevin94897
          </a>
        </nav>

        <div class="p-[22px] bg-lime/[0.04] border border-lime/20">
          <p class="font-syne text-[15px] font-bold text-white mb-1">
            {t("contact.docs")}
          </p>
          <p class="text-[12px] text-muted mb-4 leading-[1.5]">
            {t("contact.docsub")}
          </p>
          <a
            href="/files/KevinGomezLazaroCV_2026.pdf"
            download
            class="flex items-center gap-[9px] px-4 py-[12px] no-underline text-[12px] tracking-wider cursor-none mb-2 transition-all duration-300 bg-lime text-black font-medium hover:shadow-[0_0_24px_rgba(180,223,0,0.4)] hover:-translate-y-px"
          >
            <span>{t("contact.dlcv")}</span>
          </a>
          <a
            href="/files/Carta_Presentacion_KevinGomez.pdf"
            download
            class="flex w-full items-center gap-[9px] px-4 py-[11px] no-underline text-[12px] tracking-wider cursor-none mb-2 transition-all duration-300 border border-border text-muted hover:border-lime/30 hover:text-lime"
          >
            <span>{t("contact.dlcover")}</span>
          </a>
          <a
            href="/files/Carta_Recomendacion_Burns_KevinGomez.pdf"
            download
            class="flex w-full items-center gap-[9px] px-4 py-[11px] no-underline text-[12px] tracking-wider cursor-none transition-all duration-300 border border-border text-muted hover:border-lime/30 hover:text-lime"
          >
            <span>{t("contact.dlrecom")}</span>
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <div
        class="reveal-right relative z-[2] bg-white/[0.02] border border-border p-5 sm:p-8 lg:p-[44px] backdrop-blur-[20px]"
      >
        <!-- Toast notification -->
        <div
          id="formToast"
          role="alert"
          aria-live="polite"
          class="hidden mb-5 flex items-center gap-3 px-4 py-3 border text-[13px]"
        >
          <i id="formToastIcon" class="ph text-[18px]" aria-hidden="true"></i>
          <span id="formToastMsg"></span>
        </div>

        <form
          id="contactForm"
          novalidate
          aria-label="Formulario de contacto"
          data-locale={locale}
        >
          <input
            type="hidden"
            name="access_key"
            value="772ee8bc-b3f3-4011-8c6d-9df5b715383c"
          />
          <input
            type="hidden"
            id="form-subject-hidden"
            name="subject"
            value=""
          />
          <!-- Honeypot — bots fill this checkbox; submissions with it checked are discarded -->
          <input
            type="checkbox"
            name="botcheck"
            style="display:none"
            tabindex="-1"
            autocomplete="off"
          />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-[18px] gap-y-0">
            <div class="field-group mb-[14px] sm:mb-[18px]">
              <label
                for="fname"
                class="block text-[10px] tracking-[0.15em] uppercase text-muted mb-[7px]"
                >{t("form.name")}</label
              >
              <input
                type="text"
                id="fname"
                name="NOMBRE"
                autocomplete="given-name"
                placeholder={t("form.namePh")}
                required
                class="form-input w-full bg-surface2 border border-border px-[14px] py-[11px] sm:py-[13px] text-text font-sans text-[13px] sm:text-[14px] outline-none resize-none transition-[border-color,box-shadow] duration-300 focus:border-lime/40 focus:shadow-[0_0_0_3px_rgba(180,223,0,0.05)]"
              />
              <span class="field-error" aria-live="polite"></span>
            </div>
            <div class="field-group mb-[14px] sm:mb-[18px]">
              <label
                for="lname"
                class="block text-[10px] tracking-[0.15em] uppercase text-muted mb-[7px]"
                >{t("form.lastname")}</label
              >
              <input
                type="text"
                id="lname"
                name="APELLIDOS"
                autocomplete="family-name"
                placeholder={t("form.lastnamePh")}
                required
                class="form-input w-full bg-surface2 border border-border px-[14px] py-[11px] sm:py-[13px] text-text font-sans text-[13px] sm:text-[14px] outline-none resize-none transition-[border-color,box-shadow] duration-300 focus:border-lime/40 focus:shadow-[0_0_0_3px_rgba(180,223,0,0.05)]"
              />
              <span class="field-error" aria-live="polite"></span>
            </div>
          </div>

          <div class="field-group mb-[14px] sm:mb-[18px]">
            <label
              for="email"
              class="block text-[10px] tracking-[0.15em] uppercase text-muted mb-[7px]"
              >Email</label
            >
            <input
              type="email"
              id="email"
              name="EMAIL"
              autocomplete="email"
              placeholder="juan@empresa.com"
              required
              class="form-input w-full bg-surface2 border border-border px-[15px] py-[13px] text-text font-sans text-[14px] outline-none resize-none transition-[border-color,box-shadow] duration-300 focus:border-lime/40 focus:shadow-[0_0_0_3px_rgba(180,223,0,0.05)]"
            />
            <span class="field-error" aria-live="polite"></span>
          </div>

          <div class="field-group mb-[14px] sm:mb-[18px]">
            <label
              for="subject"
              class="block text-[10px] tracking-[0.15em] uppercase text-muted mb-[7px]"
              >{t("form.subject")}</label
            >
            <input
              type="text"
              id="subject"
              name="ASUNTO"
              placeholder={t("form.subjectPh")}
              required
              class="form-input w-full bg-surface2 border border-border px-[15px] py-[13px] text-text font-sans text-[14px] outline-none resize-none transition-[border-color,box-shadow] duration-300 focus:border-lime/40 focus:shadow-[0_0_0_3px_rgba(180,223,0,0.05)]"
            />
            <span class="field-error" aria-live="polite"></span>
          </div>

          <div class="field-group mb-[14px] sm:mb-[18px]">
            <label
              for="message"
              class="block text-[10px] tracking-[0.15em] uppercase text-muted mb-[7px]"
              >{t("form.message")}</label
            >
            <textarea
              id="message"
              name="MESSAGE"
              required
              placeholder={t("form.messagePh")}
              class="form-input w-full h-[90px] sm:h-[110px] bg-surface2 border border-border px-[14px] py-[11px] sm:py-[13px] text-text font-sans text-[13px] sm:text-[14px] outline-none resize-none transition-[border-color,box-shadow] duration-300 focus:border-lime/40 focus:shadow-[0_0_0_3px_rgba(180,223,0,0.05)]"
            ></textarea>
            <span class="field-error" aria-live="polite"></span>
          </div>

          <button
            id="submitBtn"
            type="submit"
            class="w-full flex items-center justify-center gap-[9px] py-[13px] sm:py-[15px] bg-lime text-black border-none text-[15px] font-medium tracking- uppercase cursor-none transition-all duration-300 hover:shadow-[0_0_36px_rgba(180,223,0,0.4)] hover:-translate-y-0.5 disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0 disabled:shadow-none"
          >
            <span id="submitLabel" data-label={t("form.send")}
              >{t("form.send")}</span
            >
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .section-label {
    @apply text-[10px] tracking-[0.25em] text-lime uppercase flex items-center gap-3 mb-[14px];
  }
  .section-label::after {
    content: "";
    @apply block w-[40px] h-px bg-lime;
  }
  .section-title {
    @apply font-syne font-extrabold leading-none text-white tracking-[-0.02em] mb-10 lg:mb-14;
    font-size: clamp(30px, 5vw, 50px);
  }
  .section-title em {
    @apply text-lime not-italic;
  }

  @media (min-width: 1024px) {
    .reveal-left {
      @apply opacity-0 -translate-x-[60px] transition-[opacity,transform] duration-[800ms] [transition-timing-function:cubic-bezier(0.23,1,0.32,1)];
    }
    .reveal-left.visible {
      @apply opacity-100 translate-x-0;
    }
    .reveal-right {
      @apply opacity-0 translate-x-[60px] transition-[opacity,transform] duration-[800ms] [transition-timing-function:cubic-bezier(0.23,1,0.32,1)];
    }
    .reveal-right.visible {
      @apply opacity-100 translate-x-0;
    }
  }

  /* ── Field validation states ── */
  .form-input.is-invalid {
    border-color: rgba(255, 80, 80, 0.6) !important;
    box-shadow: 0 0 0 3px rgba(255, 80, 80, 0.07);
  }
  .form-input.is-valid {
    border-color: rgba(180, 223, 0, 0.4) !important;
    box-shadow: 0 0 0 3px rgba(180, 223, 0, 0.05);
  }
  .field-error {
    display: block;
    font-family: "Inter", sans-serif;
    font-size: 10px;
    color: rgba(255, 90, 90, 0.9);
    letter-spacing: 0.05em;
    margin-top: 5px;
    min-height: 14px;
    transition: opacity 0.2s;
  }
  .field-error:empty {
    opacity: 0;
  }

  /* ── Toast ── */
  #formToast.toast-success {
    background: rgba(180, 223, 0, 0.06);
    border-color: rgba(180, 223, 0, 0.25);
    color: #b4df00;
  }
  #formToast.toast-error {
    background: rgba(255, 80, 80, 0.06);
    border-color: rgba(255, 80, 80, 0.25);
    color: rgba(255, 120, 120, 0.9);
  }

  /* ── Spinner ── */
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  .spin {
    animation: spin 0.7s linear infinite;
    display: inline-block;
  }
</style>

<script>
  // ── Email obfuscation — assembled at runtime so bots never see it in HTML ──
  const emailLink = document.getElementById(
    "email-contact-link",
  ) as HTMLAnchorElement | null;
  const emailLabel = document.getElementById("email-contact-label");
  if (emailLink && emailLabel) {
    const u = "kevin94897",
      d = "gmail.com";
    emailLink.href = "mailto:" + u + "@" + d;
    emailLabel.textContent = u + "@" + d;
  }

  // ── Form: validation + Web3Forms submission ──────────────────────────────
  const form = document.getElementById("contactForm") as HTMLFormElement | null;
  const toast = document.getElementById("formToast");
  const toastIcon = document.getElementById("formToastIcon");
  const toastMsg = document.getElementById("formToastMsg");
  const submitBtn = document.getElementById(
    "submitBtn",
  ) as HTMLButtonElement | null;
  const submitLabel = document.getElementById("submitLabel");
  const subjectHidden = document.getElementById(
    "form-subject-hidden",
  ) as HTMLInputElement | null;
  const isEn = document.documentElement.lang === "en";

  const MSG = {
    required: isEn ? "This field is required" : "Este campo es requerido",
    email: isEn ? "Invalid email" : "Email inválido",
    success: isEn
      ? "Message sent! I'll get back to you soon."
      : "Mensaje enviado. Te responderé pronto.",
    error: isEn
      ? "Error sending. Try again or write me directly."
      : "Error al enviar. Intenta de nuevo o escríbeme directamente.",
    sending: isEn ? "Sending…" : "Enviando…",
  };

  function showToast(success: boolean, msg: string) {
    if (!toast || !toastIcon || !toastMsg) return;
    toast.classList.remove("hidden", "toast-success", "toast-error", "flex");
    toast.classList.add("flex", success ? "toast-success" : "toast-error");
    toastIcon.className = `ph ${success ? "ph-check-circle" : "ph-warning"} text-[18px]`;
    toastMsg.textContent = msg;
    setTimeout(() => {
      toast.classList.add("hidden");
      toast.classList.remove("flex");
    }, 6000);
  }

  function validateField(
    input: HTMLInputElement | HTMLTextAreaElement,
  ): boolean {
    const group = input.closest(".field-group");
    const error = group?.querySelector(".field-error") as HTMLElement | null;
    let msg = "";
    if (input.required && !input.value.trim()) {
      msg = MSG.required;
    } else if (
      input.type === "email" &&
      input.value &&
      !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)
    ) {
      msg = MSG.email;
    }
    input.classList.toggle("is-invalid", !!msg);
    input.classList.toggle("is-valid", !msg && !!input.value.trim());
    if (error) error.textContent = msg;
    return !msg;
  }

  if (form) {
    // Real-time validation on blur / input-after-error
    form
      .querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(".form-input")
      .forEach((input) => {
        input.addEventListener("blur", () => validateField(input));
        input.addEventListener("input", () => {
          if (input.classList.contains("is-invalid")) validateField(input);
        });
      });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Validate all fields
      const inputs = Array.from(
        form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
          ".form-input",
        ),
      );
      if (!inputs.every(validateField)) return;

      // Botcheck guard
      const botcheck =
        form.querySelector<HTMLInputElement>('[name="botcheck"]');
      if (botcheck?.checked) return;

      // Build subject from ASUNTO field
      const asuntoInput =
        form.querySelector<HTMLInputElement>('[name="ASUNTO"]');
      if (subjectHidden && asuntoInput) {
        subjectHidden.value =
          "Portfolio contact – " + (asuntoInput.value.trim() || "Sin asunto");
      }

      // UI — loading state
      if (submitBtn) submitBtn.disabled = true;
      if (submitLabel)
        submitLabel.innerHTML = `<i class="ph ph-circle-notch spin text-[18px]"></i> ${MSG.sending}`;

      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          body: new FormData(form),
        });
        const json = await res.json();

        if (json.success) {
          showToast(true, MSG.success);
          form.reset();
          inputs.forEach((i) => i.classList.remove("is-valid", "is-invalid"));
        } else {
          throw new Error(json.message);
        }
      } catch {
        showToast(false, MSG.error);
      } finally {
        if (submitBtn) submitBtn.disabled = false;
        if (submitLabel)
          submitLabel.textContent =
            submitLabel.dataset.label ||
            (isEn ? "Send message" : "Enviar mensaje");
      }
    });
  }
</script>
