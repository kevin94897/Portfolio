---
// Contact.astro — Contact form + social links + CV download card
// With: real validation, Gmail SMTP send, honeypot anti-bot, toast feedback
import { useTranslations } from "../i18n/utils";

const locale = (Astro.currentLocale || "es") as "es" | "en";
const t = useTranslations(locale);
---

<section
  id="contact"
  class="py-20 lg:py-[120px] bg-black"
  aria-labelledby="contact-heading"
>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-[60px]">
    <p class="section-label">
      <span>{t("contact.label")}</span><span class="jp-tag">お問い合わせ</span>
    </p>
    <h2
      id="contact-heading"
      class="section-title-anim font-display font-bold tracking-tightest leading-none text-white mb-12"
      style="font-size: clamp(2.8rem, 5.5vw, 5.5rem); font-optical-sizing: auto; font-variation-settings: 'opsz' 32;"
    >
      {t("contact.title")}
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-6 lg:gap-[80px]">
      <!-- Left: socials + download -->
      <div class="reveal-left relative z-[2]">
        <p
          class="text-[13px] md:text-[14px] leading-[1.75] text-text/55 mb-5 lg:mb-7"
        >
          {t("contact.desc")}
        </p>

        <nav
          class="flex flex-col gap-[7px] mb-[18px] lg:mb-[22px]"
          aria-label={t("contact.nav_aria")}
        >
          <a
            href="tel:+51947841355"
            class="flex items-center gap-3 px-3 py-[10px] lg:px-4 lg:py-3 bg-surface border border-border text-text no-underline text-[12px] lg:text-[13px] transition-all duration-300 hover:border-lime/30 hover:translate-x-1 hover:text-lime hover:shadow-[0_0_18px_rgba(180,223,0,0.05)]"
          >
            <i class="ph ph-phone text-[17px] text-lime" aria-hidden="true"></i>
            +51 947 841 355
          </a>
          <a
            id="email-link"
            href="#"
            class="flex items-center gap-3 px-3 py-[10px] lg:px-4 lg:py-3 bg-surface border border-border text-text no-underline text-[12px] lg:text-[13px] transition-all duration-300 hover:border-lime/30 hover:translate-x-1 hover:text-lime hover:shadow-[0_0_18px_rgba(180,223,0,0.05)]"
          >
            <i class="ph ph-envelope text-[17px] text-lime" aria-hidden="true"
            ></i>
            <span id="email-label"></span>
          </a>
          <a
            href="https://kevin-gomez.dev"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 px-3 py-[10px] lg:px-4 lg:py-3 bg-surface border border-border text-text no-underline text-[12px] lg:text-[13px] transition-all duration-300 hover:border-lime/30 hover:translate-x-1 hover:text-lime hover:shadow-[0_0_18px_rgba(180,223,0,0.05)]"
          >
            <i class="ph ph-globe text-[17px] text-lime" aria-hidden="true"></i>
            kevin.grupo-gomez.com
          </a>
          <a
            href="https://github.com/kevin94897/"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 px-3 py-[10px] lg:px-4 lg:py-3 bg-surface border border-border text-text no-underline text-[12px] lg:text-[13px] transition-all duration-300 hover:border-lime/30 hover:translate-x-1 hover:text-lime hover:shadow-[0_0_18px_rgba(180,223,0,0.05)]"
          >
            <i
              class="ph ph-github-logo text-[17px] text-lime"
              aria-hidden="true"></i>
            github.com/kevin94897
          </a>
        </nav>

        <div class="p-[22px] bg-lime/[0.04] border border-lime/20">
          <p class="font-syne text-[15px] font-bold text-white mb-1">
            {t("contact.docs")}
          </p>
          <p class="text-[12px] text-muted mb-4 leading-[1.5]">
            {t("contact.docsub")}
          </p>
          <a
            href="/files/KevinGomezLazaroCV_2026.pdf"
            download
            class="flex items-center gap-[9px] px-4 py-[12px] no-underline text-[12px] tracking-wider cursor-none mb-2 transition-all duration-300 bg-lime text-black font-medium hover:shadow-[0_0_24px_rgba(180,223,0,0.4)] hover:-translate-y-px"
          >
            <span>{t("contact.dlcv")}</span>
          </a>
          <a
            href="/files/Carta_Presentacion_KevinGomez.pdf"
            download
            class="flex w-full items-center gap-[9px] px-4 py-[11px] no-underline text-[12px] tracking-wider cursor-none mb-2 transition-all duration-300 border border-border text-muted hover:border-lime/30 hover:text-lime"
          >
            <span>{t("contact.dlcover")}</span>
          </a>
          <a
            href="/files/Carta_Recomendacion_Burns_KevinGomez.pdf"
            download
            class="flex w-full items-center gap-[9px] px-4 py-[11px] no-underline text-[12px] tracking-wider cursor-none transition-all duration-300 border border-border text-muted hover:border-lime/30 hover:text-lime"
          >
            <span>{t("contact.dlrecom")}</span>
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <div
        class="reveal-right relative z-[2] bg-white/[0.02] border border-border p-5 sm:p-8 lg:p-[44px] backdrop-blur-[20px]"
      >
        <!-- Toast notification -->
        <div
          id="formToast"
          role="alert"
          aria-live="polite"
          class="hidden mb-5 flex items-center gap-3 px-4 py-3 border text-[13px]"
        >
          <i id="formToastIcon" class="ph text-[18px]" aria-hidden="true"></i>
          <span id="formToastMsg"></span>
        </div>

        <form id="contactForm" novalidate aria-label={t("contact.form_aria")}>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-[18px] gap-y-0">
            <div class="field-group mb-[14px] sm:mb-[18px]">
              <label
                for="fname"
                class="block text-[10px] tracking-[0.15em] uppercase text-muted mb-[7px]"
                >{t("form.name")}</label
              >
              <input
                type="text"
                id="fname"
                name="NOMBRE"
                autocomplete="given-name"
                placeholder={t("form.namePh")}
                required
                class="form-input w-full bg-surface2 border border-border px-[14px] py-[11px] sm:py-[13px] text-text font-sans text-[13px] sm:text-[14px] outline-none resize-none transition-[border-color,box-shadow] duration-300 focus:border-lime/40 focus:shadow-[0_0_0_3px_rgba(180,223,0,0.05)]"
              />
              <span class="field-error" aria-live="polite"></span>
            </div>
            <div class="field-group mb-[14px] sm:mb-[18px]">
              <label
                for="lname"
                class="block text-[10px] tracking-[0.15em] uppercase text-muted mb-[7px]"
                >{t("form.lastname")}</label
              >
              <input
                type="text"
                id="lname"
                name="APELLIDOS"
                autocomplete="family-name"
                placeholder={t("form.lastnamePh")}
                required
                class="form-input w-full bg-surface2 border border-border px-[14px] py-[11px] sm:py-[13px] text-text font-sans text-[13px] sm:text-[14px] outline-none resize-none transition-[border-color,box-shadow] duration-300 focus:border-lime/40 focus:shadow-[0_0_0_3px_rgba(180,223,0,0.05)]"
              />
              <span class="field-error" aria-live="polite"></span>
            </div>
          </div>

          <div class="field-group mb-[14px] sm:mb-[18px]">
            <label
              for="email"
              class="block text-[10px] tracking-[0.15em] uppercase text-muted mb-[7px]"
              >Email</label
            >
            <input
              type="email"
              id="email"
              name="EMAIL"
              autocomplete="email"
              placeholder={t("form.emailPh")}
              required
              class="form-input w-full bg-surface2 border border-border px-[15px] py-[13px] text-text font-sans text-[14px] outline-none resize-none transition-[border-color,box-shadow] duration-300 focus:border-lime/40 focus:shadow-[0_0_0_3px_rgba(180,223,0,0.05)]"
            />
            <span class="field-error" aria-live="polite"></span>
          </div>

          <div class="field-group mb-[14px] sm:mb-[18px]">
            <label
              for="subject"
              class="block text-[10px] tracking-[0.15em] uppercase text-muted mb-[7px]"
              >{t("form.subject")}</label
            >
            <input
              type="text"
              id="subject"
              name="ASUNTO"
              placeholder={t("form.subjectPh")}
              required
              class="form-input w-full bg-surface2 border border-border px-[15px] py-[13px] text-text font-sans text-[14px] outline-none resize-none transition-[border-color,box-shadow] duration-300 focus:border-lime/40 focus:shadow-[0_0_0_3px_rgba(180,223,0,0.05)]"
            />
            <span class="field-error" aria-live="polite"></span>
          </div>

          <div class="field-group mb-[14px] sm:mb-[18px]">
            <label
              for="message"
              class="block text-[10px] tracking-[0.15em] uppercase text-muted mb-[7px]"
              >{t("form.message")}</label
            >
            <textarea
              id="message"
              name="MESSAGE"
              placeholder={t("form.messagePh")}
              class="form-input w-full h-[90px] sm:h-[110px] bg-surface2 border border-border px-[14px] py-[11px] sm:py-[13px] text-text font-sans text-[13px] sm:text-[14px] outline-none resize-none transition-[border-color,box-shadow] duration-300 focus:border-lime/40 focus:shadow-[0_0_0_3px_rgba(180,223,0,0.05)]"
            ></textarea>
            <span class="field-error" aria-live="polite"></span>
          </div>

          <button
            id="submitBtn"
            type="submit"
            class="w-full flex items-center justify-center gap-[9px] py-[13px] sm:py-[15px] bg-lime text-black border-none text-[15px] font-medium tracking-tight uppercase cursor-none transition-all duration-300 hover:shadow-[0_0_36px_rgba(180,223,0,0.4)] hover:-translate-y-0.5 disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0 disabled:shadow-none"
          >
            <i
              id="submitIcon"
              class="ph ph-paper-plane-tilt text-[17px]"
              aria-hidden="true"></i>
            <span id="submitLabel">{t("form.send")}</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .section-label {
    @apply text-[10px] tracking-[0.25em] text-lime uppercase flex items-center gap-3 mb-[14px];
  }
  .section-label::after {
    content: "";
    @apply block w-[40px] h-px bg-lime;
  }
  .section-title {
    @apply font-syne font-extrabold leading-none text-white tracking-[-0.02em] mb-10 lg:mb-14;
    font-size: clamp(30px, 5vw, 50px);
  }
  .section-title em {
    @apply text-lime not-italic;
  }

  @media (min-width: 1024px) {
    .reveal-left {
      @apply opacity-0 -translate-x-[60px] transition-[opacity,transform] duration-[800ms] [transition-timing-function:cubic-bezier(0.23,1,0.32,1)];
    }
    .reveal-left.visible {
      @apply opacity-100 translate-x-0;
    }
    .reveal-right {
      @apply opacity-0 translate-x-[60px] transition-[opacity,transform] duration-[800ms] [transition-timing-function:cubic-bezier(0.23,1,0.32,1)];
    }
    .reveal-right.visible {
      @apply opacity-100 translate-x-0;
    }
  }

  /* ── Field validation states ── */
  .form-input.is-invalid {
    border-color: rgba(255, 80, 80, 0.6) !important;
    box-shadow: 0 0 0 3px rgba(255, 80, 80, 0.07);
  }
  .form-input.is-valid {
    border-color: rgba(180, 223, 0, 0.4) !important;
    box-shadow: 0 0 0 3px rgba(180, 223, 0, 0.05);
  }
  .field-error {
    display: block;
    font-family: "Inter", sans-serif;
    font-size: 10px;
    color: rgba(255, 90, 90, 0.9);
    letter-spacing: 0.05em;
    margin-top: 5px;
    min-height: 14px;
    transition: opacity 0.2s;
  }
  .field-error:empty {
    opacity: 0;
  }

  /* ── Toast ── */
  #formToast.toast-success {
    background: rgba(180, 223, 0, 0.06);
    border-color: rgba(180, 223, 0, 0.25);
    color: #b4df00;
  }
  #formToast.toast-error {
    background: rgba(255, 80, 80, 0.06);
    border-color: rgba(255, 80, 80, 0.25);
    color: rgba(255, 120, 120, 0.9);
  }

  /* ── Spinner ── */
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  .spin {
    animation: spin 0.7s linear infinite;
    display: inline-block;
  }
</style>

<script>
  const emailLink = document.getElementById(
    "email-link",
  ) as HTMLAnchorElement | null;
  const emailLabel = document.getElementById("email-label");
  if (emailLink && emailLabel) {
    const e = atob("a2V2aW45NDg5N0BnbWFpbC5jb20=");
    emailLink.href = "mailto:" + e;
    emailLabel.textContent = e;
  }
</script>
