---
import { useTranslations } from '../i18n/utils';

const locale = (Astro.currentLocale || 'es') as 'es' | 'en';
const t = useTranslations(locale);

const jobs = [
  {
    year: '2025',
    title: 'Full Stack Developer',
    company: 'NERD — Lima, Perú',
    descKey: 'exp.nerd',
    tags: ['Next.js', 'NestJS', 'React', 'Tailwind', 'Zoho'],
  },
  {
    year: '2021 — 2025',
    title: 'Full Stack Developer',
    company: 'SrBurns — Miraflores, Lima',
    descKey: 'exp.srburns',
    tags: ['Astro', 'WP Headless', 'Node.js', 'SCSS', 'Figma'],
  },
  {
    year: '2020 — 2021',
    title: 'Web Developer',
    company: 'Well-Done Media — Puerto Rico',
    descKey: 'exp.wellDone',
    tags: ['React', 'Vue.js', 'Shopify', 'GTM', 'Zapier'],
  },
  {
    year: '2020',
    title: 'Full Stack Developer',
    company: 'One Blush Salon — Miraflores',
    descKey: 'exp.oneBlush',
    tags: ['Laravel', 'CodeIgniter', 'Vue.js', 'REST API'],
  },
  {
    year: '2019 — 2020',
    title: 'Web Developer',
    company: 'Softbrilliance — San Borja',
    descKey: 'exp.soft',
    tags: ['WordPress', 'SEO', 'Analytics'],
  },
  {
    year: '2017 — 2018',
    title: 'Freelancer',
    company: 'Vex Soluciones — Lima',
    descKey: 'exp.vex',
    tags: ['WooCommerce', 'Shopify', 'UX'],
  },
];
---

<section
  id="experience"
  class="px-6 md:px-10 py-24 border-b border-border bg-black"
  aria-labelledby="exp-heading"
>

  <!-- Label -->
  <div class="flex items-center gap-3 mb-4 max-w-[1400px] mx-auto">
    <span class="text-[10px] tracking-widest uppercase text-muted">{t('exp.label')}</span>
    <span class="text-[10px] text-muted/40 tracking-[0.06em]">職歴</span>
  </div>

  <!-- Header -->
  <div class="flex items-start justify-between mb-12 max-w-[1400px] mx-auto">
    <h2
      id="exp-heading"
      class="section-title-anim font-display font-bold tracking-tightest leading-none text-white"
      style="font-size: clamp(2.8rem, 5.5vw, 5.5rem); font-optical-sizing: auto; font-variation-settings: 'opsz' 32;"
    >
      {t('exp.work')}
    </h2>
  </div>

  <!-- Company bar -->
  <div class="border-y border-border py-4 mb-0 bg-lime overflow-x-auto scrollbar-hide">
    <div class="flex items-center gap-8 md:gap-6 md:justify-between px-6 md:px-10 md:max-w-[1400px] md:mx-auto w-max md:w-full">
      {['NERD', 'SrBurns', 'Well-Done', 'One Blush', 'Softbrilliance', 'Vex'].map((c) => (
        <span class="text-[11px] md:text-[12px] tracking-widest uppercase text-black font-semibold whitespace-nowrap">
          {c}
        </span>
      ))}
    </div>
  </div>

  <!-- Job rows -->
  <div class="max-w-[1400px] mx-auto" role="list">
    {jobs.map((job) => (
      <div
        class="group grid grid-cols-1 md:grid-cols-[140px_1fr_2fr_auto] items-start border-t border-border py-8 md:py-10 gap-4 md:gap-8 transition-colors duration-300 hover:bg-white/[0.02]"
        role="listitem"
        data-job-row
      >
        <!-- Year -->
        <time class="text-[11px] text-muted tracking-widest pt-1">
          {job.year}
        </time>

        <!-- Title + company -->
        <div>
          <h3
            class="font-display font-bold text-xl md:text-2xl tracking-tightest text-white transition-colors duration-300 group-hover:text-lime"
            style="font-optical-sizing: auto;"
          >
            {job.title}
          </h3>
          <p class="text-[12px] text-lime/60 mt-1">{job.company}</p>
        </div>

        <!-- Description -->
        <p class="text-white text-[13px] md:text-[14px] leading-relaxed">
          {t(job.descKey)}
        </p>

        <!-- Tags -->
        <div class="flex flex-wrap gap-[5px] md:justify-end">
          {job.tags.map((tag) => (
            <span class="text-[9px] tracking-widest uppercase px-[7px] py-[3px] border border-border text-muted">
              {tag}
            </span>
          ))}
        </div>
      </div>
    ))}
    <!-- Closing border -->
    <div class="border-t border-border"></div>
  </div>

</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>("[data-job-row]").forEach((row) => {
    gsap.from(row, {
      scrollTrigger: { trigger: row, start: "top 90%" },
      opacity: 0,
      y: 32,
      duration: 0.65,
      ease: "power2.out",
    });
  });
</script>

