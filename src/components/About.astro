---
import fotoKevin from "../assets/images/foto_kevin.jpeg";
import portrait from "../assets/images/foto_portrait_kevin.jpeg";
import { useTranslations } from "../i18n/utils";

const locale = (Astro.currentLocale || "es") as "es" | "en";
const t = useTranslations(locale);
---

<!-- Floating portrait — follows cursor inside About section --><!-- <div id="about-floating-img" aria-hidden="true">
  <img src={portrait.src} alt="" />
</div> -->
<section
  id="about"
  class="px-6 md:px-10 py-24 border-b border-border bg-black"
  aria-labelledby="about-heading"
>
  <div class="max-w-[1400px] mx-auto">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Left: portrait image -->
      <div
        class="reveal-left relative aspect-[3/4] max-w-sm w-full overflow-hidden group"
      >
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent z-10"
        >
        </div>
        <img
          src={portrait.src}
          alt="Kevin Gómez Lázaro — Full Stack Developer"
          class="w-full h-full object-cover object-top grayscale transition-transform duration-700 ease-out group-hover:scale-[1.06]"
        />
        <div class="absolute bottom-5 left-5 z-20">
          <span
            class="text-[10px] tracking-widest uppercase text-muted/80 bg-black/80 px-2 py-1"
          >
            Full Stack Developer
          </span>
        </div>
      </div>

      <!-- Right: content -->
      <div class="reveal-right">
        <!-- Section label -->
        <div class="flex items-center gap-3 mb-8">
          <span class="text-[10px] tracking-widest uppercase text-muted"
            >{t("about.label")}</span
          >
          <span class="text-[10px] text-muted/40 tracking-[0.06em]"
            >プロフィール</span
          >
        </div>

        <!-- Big display headline -->
        <h2
          id="about-heading"
          class="section-title-anim font-display font-bold leading-[0.88] tracking-tightest text-white mb-8"
          style="font-size: clamp(2.8rem, 5.5vw, 5.5rem); font-optical-sizing: auto; font-variation-settings: 'opsz' 32;"
          set:html={t("about.title")}
        />

        <!-- Bio -->
        <p
          class="text-muted text-[14px] leading-relaxed mb-5 max-w-md"
          set:html={t("about.bio1")}
        />
        <p
          class="text-muted text-[14px] leading-relaxed mb-10 max-w-md"
          set:html={t("about.bio2")}
        />

        <!-- CTA buttons -->
        <div class="flex gap-3 flex-wrap mb-14">
          <a
            href="/files/KevinGomezLazaroCV_2026.pdf"
            download
            class="inline-flex items-center gap-2 bg-lime text-black px-6 py-3 text-[14px] font-semibold md:tracking-wider uppercase no-underline transition-all duration-300 hover:opacity-90 hover:-translate-y-0.5"
          >
            <span>{t("about.cv")}</span>
          </a>
          <a
            href="#contact"
            class="inline-flex items-center gap-2 border border-border text-text bg-transparent px-6 py-3 text-[14px] font-semibold md:tracking-wider uppercase no-underline transition-all duration-300 hover:border-lime hover:text-lime"
          >
            <span>{t("about.contact")}</span>
          </a>
        </div>

        <!-- Stats row -->
        <div class="grid grid-cols-3 gap-6 pt-8 border-t border-border">
          <div>
            <div
              class="font-display font-bold text-4xl md:text-5xl text-lime tracking-tightest leading-none mb-1"
              style="font-optical-sizing: auto;"
            >
              8+
            </div>
            <div class="text-[10px] tracking-widest uppercase text-muted">
              {t("about.stat1")}
            </div>
          </div>
          <div>
            <div
              class="font-display font-bold text-4xl md:text-5xl text-lime tracking-tightest leading-none mb-1"
              style="font-optical-sizing: auto;"
            >
              20+
            </div>
            <div class="text-[10px] tracking-widest uppercase text-muted">
              {t("about.stat2")}
            </div>
          </div>
          <div>
            <div
              class="font-display font-bold text-4xl md:text-5xl text-lime tracking-tightest leading-none mb-1"
              style="font-optical-sizing: auto;"
            >
              95
            </div>
            <div class="text-[10px] tracking-widest uppercase text-muted">
              SFPC Score
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tech stack — full width below grid -->
    <div class="mt-16 pt-10 border-t border-border">
      <p class="text-[10px] tracking-widest uppercase text-muted mb-6">
        {t("about.stack")}
      </p>
      <div
        class="skills-grid flex flex-wrap gap-2"
        role="list"
        aria-label="Tecnologías dominadas"
      >
        {
          [
            "Next.js",
            "React / Vite",
            "NestJS",
            "Astro",
            "Vue.js",
            "Angular",
            "Laravel",
            "PHP / CodeIgniter",
            "Node.js",
            "Tailwind CSS",
            "SCSS / Pug",
            "WordPress Headless",
            "Shopify",
            "PrestaShop",
            "WooCommerce",
            "SQL / MySQL",
            "REST APIs / JSON",
            "Figma / Zeplin",
            "Flutter",
            "Git / Scrum / Jira",
          ].map((tech) => (
            <div
              class="skill-pill flex items-center gap-[7px] px-[11px] py-[6px] bg-surface2 border border-border text-[10px] md:text-[11px] text-text
                   transition-[border-color,box-shadow,transform] duration-200
                   hover:border-lime hover:shadow-[0_0_14px_rgba(180,223,0,0.12)] hover:-translate-y-0.5"
              role="listitem"
            >
              <div
                class="w-[5px] h-[5px] rounded-full bg-lime flex-shrink-0"
                aria-hidden="true"
              />
              {tech}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  @media (min-width: 768px) {
    .reveal-left {
      @apply opacity-0 -translate-x-[60px] transition-[opacity,transform] duration-[800ms] [transition-timing-function:cubic-bezier(0.23,1,0.32,1)];
    }
    .reveal-left.visible {
      @apply opacity-100 translate-x-0;
    }

    .reveal-right {
      @apply opacity-0 translate-x-[60px] transition-[opacity,transform] duration-[800ms] [transition-timing-function:cubic-bezier(0.23,1,0.32,1)];
    }
    .reveal-right.visible {
      @apply opacity-100 translate-x-0;
    }
  }

  @media (min-width: 768px) {
    .skill-pill {
      @apply opacity-0 translate-y-2;
    }
    .skill-pill.visible {
      @apply opacity-100 translate-y-0;
    }
  }
</style>

<style is:global>
  #about-floating-img {
    position: fixed;
    top: 0;
    left: 0;
    width: 160px;
    height: 210px;
    pointer-events: none;
    z-index: 999;
    opacity: 0;
    overflow: hidden;
    transition:
      opacity 0.35s cubic-bezier(0.23, 1, 0.32, 1),
      scale 0.35s cubic-bezier(0.23, 1, 0.32, 1);
    scale: 0.85;
    will-change: transform;
  }
  #about-floating-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    filter: grayscale(100%);
  }
</style>

<script>
  const section = document.getElementById("about");
  const floatEl = document.getElementById(
    "about-floating-img",
  ) as HTMLElement | null;
  if (section && floatEl) {
    let tx = 0,
      ty = 0,
      cx = 0,
      cy = 0;

    document.addEventListener("mousemove", (e) => {
      tx = e.clientX - 80;
      ty = e.clientY - 105;
    });

    (function loop() {
      cx += (tx - cx) * 0.1;
      cy += (ty - cy) * 0.1;
      floatEl.style.transform = `translate(${cx}px, ${cy}px)`;
      requestAnimationFrame(loop);
    })();

    section.addEventListener("mouseenter", () => {
      floatEl.style.opacity = "1";
      floatEl.style.scale = "1";
    });
    section.addEventListener("mouseleave", () => {
      floatEl.style.opacity = "0";
      floatEl.style.scale = "0.85";
    });
  }
</script>
