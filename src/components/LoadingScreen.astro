---
// LoadingScreen.astro
// Full-screen animated loading screen with lime progress bar
// Disappears smoothly on window load
import logo from '../assets/images/logo-kevin.png';
---

<div
  id="loading-screen"
  role="progressbar"
  aria-label="Cargando portfolio"
  aria-busy="true"
  class="fixed inset-0 bg-black z-[99999] flex flex-col items-center justify-center gap-7
         transition-[opacity,visibility] duration-700 [transition-timing-function:cubic-bezier(0.4,0,0.2,1)]"
>
  <img
    src={logo.src}
    alt="Kevin Gómez Logo"
    class="h-12 sm:h-16 w-auto [animation:loadingPulse_1.5s_ease-in-out_infinite]"
  />

  <p class="font-mono text-[11px] tracking-[0.25em] uppercase text-muted -mt-4">
    Full Stack Developer · Lima, Perú
  </p>

  <div class="w-[200px] h-[2px] bg-white/[0.07] rounded-[2px] overflow-hidden">
    <div class="h-full bg-lime rounded-[2px] w-0 shadow-[0_0_8px_rgba(180,223,0,0.4)] [animation:loadBar_1.6s_cubic-bezier(0.4,0,0.2,1)_forwards]"></div>
  </div>
</div>

<style>
  #loading-screen.hidden {
    @apply opacity-0 invisible pointer-events-none;
  }

  @keyframes loadBar {
    0%   { width: 0%; }
    40%  { width: 55%; }
    80%  { width: 85%; }
    100% { width: 100%; }
  }

  @keyframes loadingPulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.6; }
  }
</style>

<script>
  function hideLoader() {
    const screen = document.getElementById('loading-screen');
    if (!screen) return;
    setTimeout(() => {
      screen.classList.add('hidden');
      screen.addEventListener('transitionend', () => screen.remove(), { once: true });
    }, 800);
  }

  if (document.readyState === 'complete') {
    hideLoader();
  } else {
    window.addEventListener('load', hideLoader);
  }
</script>
