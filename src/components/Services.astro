---
const services = [
  {
    num: '01',
    nameKey: 'services.s1.name',
    name: 'Full Stack Dev',
    descKey: 'services.s1.desc',
    desc: 'Aplicaciones web end-to-end con React, Next.js, NestJS, Laravel y Node.js. Diseño de APIs REST, autenticación y lógica de negocio.',
  },
  {
    num: '02',
    nameKey: 'services.s2.name',
    name: 'Diseño & UX',
    descKey: 'services.s2.desc',
    desc: 'Interfaces responsivas desde Figma hasta código. Evaluación heurística, prototipado y diseño centrado en el usuario.',
  },
  {
    num: '03',
    nameKey: 'services.s3.name',
    name: 'E-Commerce',
    descKey: 'services.s3.desc',
    desc: 'Tiendas con WooCommerce, Shopify y PrestaShop. Pasarelas de pago, Zoho CRM y automatizaciones con Zapier.',
  },
  {
    num: '04',
    nameKey: 'services.s4.name',
    name: 'SEO & Analytics',
    descKey: 'services.s4.desc',
    desc: 'SEO técnico y on-page, GTM, Google Analytics, Facebook Pixel, SEMRush, Screaming Frog y reportes de leads.',
  },
];
---

<section
  id="services"
  class="px-6 md:px-10 py-24 border-b border-border bg-black"
  aria-labelledby="services-heading"
>

  <!-- Label -->
  <div class="flex items-center gap-3 mb-4 max-w-[1400px] mx-auto">
    <span class="text-[10px] tracking-widest uppercase text-muted" data-i18n="services.label">02 — Servicios</span>
    <span class="text-[10px] text-muted/40 tracking-[0.06em]">サービス</span>
  </div>

  <!-- Header -->
  <div class="flex items-end justify-between mb-12 max-w-[1400px] mx-auto">
    <h2
      id="services-heading"
      class="section-title-anim font-display font-bold tracking-tightest leading-none text-white"
      style="font-size: clamp(2.8rem, 5.5vw, 5.5rem); font-optical-sizing: auto; font-variation-settings: 'opsz' 32;"
      data-i18n-html="services.title"
    >
      Services
    </h2>
  </div>

  <!-- Descriptor bar -->
  <div class="border-y border-border py-4 mb-0 bg-lime overflow-x-auto scrollbar-hide">
    <div class="flex items-center gap-8 md:gap-6 md:justify-between px-6 md:px-10 md:max-w-[1400px] md:mx-auto w-max md:w-full">
      {['Reliable', 'Scalable', 'Focused', 'Full Stack'].map((label) => (
        <span class="text-[11px] md:text-[12px] tracking-widest uppercase text-black font-semibold whitespace-nowrap">
          {label}
        </span>
      ))}
    </div>
  </div>

  <!-- Service rows -->
  <div class="max-w-[1400px] mx-auto" role="list">
    {services.map((s) => (
      <div
        class="service-row group grid grid-cols-1 md:grid-cols-[2fr_3rem_2fr_3fr] items-start border-t border-border py-8 md:py-10 px-6 md:px-10 gap-4 md:gap-8 transition-colors duration-300 hover:bg-white/[0.02]"
        role="listitem"
      >
        <!-- Empty spacer (desktop only) -->
        <div class="hidden md:block" aria-hidden="true"></div>

        <!-- Number -->
        <span class="text-[11px] text-muted tracking-widest pt-1 hidden md:block">
          ({s.num})
        </span>

        <!-- Name -->
        <h3
          class="font-display font-bold text-2xl md:text-3xl lg:text-4xl tracking-tightest text-white transition-colors duration-300 group-hover:text-lime"
          style="font-optical-sizing: auto;"
          data-i18n={s.nameKey}
        >
          {s.name}
        </h3>

        <!-- Description -->
        <p
          class="text-muted text-[13px] md:text-[14px] leading-relaxed max-w-sm"
          data-i18n={s.descKey}
        >
          {s.desc}
        </p>
      </div>
    ))}
    <!-- Closing border -->
    <div class="border-t border-border mx-6 md:mx-10"></div>
  </div>

</section>
