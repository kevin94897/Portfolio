---
import logo from "../assets/images/logo-kevin.png";
const year = new Date().getFullYear();
---

<footer
  class="px-6 md:px-10 pt-24 pb-10 border-t border-border"
  role="contentinfo"
>
  <!-- Big CTA -->
  <div class="mb-20 text-center">
    <h2
      class="section-title-anim font-display font-semibold leading-none select-none cursor-default mb-8 transition-colors duration-500 tracking-tight"
      style="font-size: clamp(4rem, 12vw, 14rem); font-optical-sizing: auto; font-variation-settings: 'opsz' 32; color: rgba(232,232,232,232);"
    >
      Let's Work.
    </h2>
    <a
      href="#contact"
      class="inline-flex items-center gap-2 bg-lime px-6 py-3 text-sm tracking-widest uppercase text-black no-underline transition-all duration-300 hover:bg-lime-glow hover:text-black"
    >
      <span>Start a Project →</span>
    </a>
  </div>

  <!-- Footer grid -->
  <div class="grid md:grid-cols-4 gap-12 pt-12 border-t border-border">
    <!-- Brand -->
    <div class="md:col-span-2">
      <a
        href="#hero"
        aria-label="Kevin Gómez — Volver al inicio"
        class="inline-block mb-4"
      >
        <img src={logo.src} alt="Kevin Gómez Logo" class="h-8 w-auto" />
      </a>
      <p class="text-muted text-sm leading-relaxed max-w-xs">
        Full Stack Developer especializado en React, Next.js, NestJS y
        E-Commerce. Disponible para proyectos freelance desde Lima, Perú.
      </p>
    </div>

    <!-- Quick Links -->
    <div>
      <p class="text-[10px] tracking-widest uppercase mb-4">Quick Links</p>
      <nav class="flex flex-col gap-2" aria-label="Secciones">
        {
          [
            { label: "Sobre Mí", href: "#about" },
            { label: "Proyectos", href: "#projects" },
            { label: "Servicios", href: "#services" },
            { label: "Contacto", href: "#contact" },
          ].map((link) => (
            <a
              href={link.href}
              class="text-sm text-muted no-underline transition-colors duration-200 hover:text-lime"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <!-- Networks -->
    <div>
      <p class="text-[12px] mb-4">Networks</p>
      <nav class="flex flex-col gap-2" aria-label="Redes sociales">
        {
          [
            { label: "GitHub", href: "https://github.com/kevin94897/" },
            { label: "LinkedIn", href: "#" },
            { label: "Instagram", href: "#" },
            { label: "Facebook", href: "#" },
          ].map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-muted no-underline transition-colors duration-200 hover:text-lime"
            >
              {link.label} ↗
            </a>
          ))
        }
      </nav>
    </div>
  </div>

  <!-- Bottom bar -->
  <div
    class="flex flex-col md:flex-row items-center justify-between gap-4 mt-12 pt-6 border-t border-border"
  >
    <span class="text-[10px] tracking-widest uppercase text-muted">
      &copy;{year} Kevin Gómez Lázaro — All Rights Reserved
    </span>
    <span class="text-[10px] tracking-widest uppercase text-muted">
      Full Stack Developer — Lima, Perú
    </span>
  </div>
</footer>
