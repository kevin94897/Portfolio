---
// Footer.astro — Copyright bar with logo and footer links
import logo from '../assets/images/logo-kevin.png';
const year = new Date().getFullYear();
---

<footer class="bg-black border-t border-border py-[34px]" role="contentinfo">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-[60px]">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-center sm:text-left">

      <a href="#hero" aria-label="Kevin Gómez — Volver al inicio">
        <img src={logo.src} alt="Kevin Gómez Logo" class="h-8 w-auto" />
      </a>

      <small class="font-mono text-[10px] text-muted tracking-[0.05em]">
        &copy; {year} Kevin Gómez Lázaro — Full Stack Developer
      </small>

      <nav class="flex gap-[22px]" aria-label="Enlaces del pie de página">
        <a href="#about"    data-i18n="nav.about"    class="font-mono text-[10px] text-muted no-underline transition-colors duration-200 hover:text-lime">About</a>
        <a href="#projects" data-i18n="nav.projects" class="font-mono text-[10px] text-muted no-underline transition-colors duration-200 hover:text-lime">Proyectos</a>
        <a href="#contact"  data-i18n="nav.contact"  class="font-mono text-[10px] text-muted no-underline transition-colors duration-200 hover:text-lime">Contacto</a>
      </nav>

    </div>
  </div>
</footer>
