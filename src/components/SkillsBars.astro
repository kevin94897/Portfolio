---
import { useTranslations } from '../i18n/utils';

const locale = (Astro.currentLocale || 'es') as 'es' | 'en';
const t = useTranslations(locale);

interface Skill {
  name: string;
  cat: string;
  level: "Expert" | "Senior" | "Mid";
  pct: number;
}

const skills: Skill[] = [
  { name: "HTML5 / CSS3 / SCSS", cat: "Desarrollo", level: "Expert", pct: 100 },
  {
    name: "PHP / Laravel / CodeIgniter",
    cat: "Desarrollo",
    level: "Expert",
    pct: 97,
  },
  { name: "WordPress Headless", cat: "Herramientas", level: "Expert", pct: 97 },
  { name: "SEO Técnico / On-Page", cat: "Marketing", level: "Expert", pct: 95 },
  {
    name: "Shopify / PrestaShop",
    cat: "Herramientas",
    level: "Expert",
    pct: 93,
  },
  { name: "Scrum / Git / Jira", cat: "Workflow", level: "Expert", pct: 92 },
  { name: "Astro / Tailwind CSS", cat: "Desarrollo", level: "Expert", pct: 90 },
  {
    name: "React / Next.js / Vite",
    cat: "Desarrollo",
    level: "Senior",
    pct: 88,
  },
  { name: "SQL / REST APIs", cat: "Desarrollo", level: "Senior", pct: 88 },
  {
    name: "SEMRush / Screaming Frog",
    cat: "Marketing",
    level: "Senior",
    pct: 88,
  },
  {
    name: "Google Analytics / GTM",
    cat: "Marketing",
    level: "Senior",
    pct: 85,
  },
  { name: "Node.js / NestJS", cat: "Desarrollo", level: "Senior", pct: 82 },
  { name: "Figma / Zeplin", cat: "Diseño", level: "Senior", pct: 80 },
  { name: "Vue.js / Angular", cat: "Desarrollo", level: "Mid", pct: 72 },
];

const marqueeText = t('skills.title');
---

<section
  id="skills"
  class="pt-16 lg:pt-[100px] pb-20 lg:pb-[120px] bg-black overflow-hidden"
  aria-labelledby="skills-heading"
>
  <!-- Label row -->
  <div class="max-w-[1400px] mx-auto px-6 lg:px-[60px] mb-6 reveal">
    <div class="flex items-center justify-between">
      <p class="section-label !mb-0">
        <span>{t('skills.label')}</span>
        <span class="jp-tag">スキル</span>
      </p>
      <span
        class="text-[9px] tracking-[0.22em] uppercase hidden md:block"
        style="color:rgba(255,255,255,0.18);">TECH SKILLS</span
      >
    </div>
  </div>

  <!-- Accessible heading (screen readers) -->
  <h2 id="skills-heading" class="sr-only">
    {t('skills.title')}
  </h2>

  <!-- ── Marquee ── -->
  <div class="max-w-[1400px] mx-auto px-6 lg:px-[60px]">
    <div
      class="skills-marquee border-t border-b border-border py-3 lg:py-4 mb-10 lg:mb-14 overflow-hidden"
    >
      <div class="skills-track flex whitespace-nowrap" aria-hidden="true">
        {
          /* Two identical copies → seamless -50% loop */
          [0, 1].map(() => (
            <span
              class="skills-track-item inline-flex items-baseline gap-5 lg:gap-7 pr-6 lg:pr-10 flex-shrink-0 font-display font-bold tracking-tightest leading-none text-white select-none"
              style="font-size:clamp(4.2rem,10vw,9.5rem);font-optical-sizing:auto;font-variation-settings:'opsz' 72;"
            >
              {marqueeText}
              <span
                class="text-lime"
                style="font-size:0.38em;letter-spacing:0.04em;font-weight:800;"
              >
                スキル
              </span>
              <span style="font-size:0.28em;color:rgba(255,255,255,0.15);font-weight:400;">
                ·
              </span>
              {marqueeText}
              <span
                class="text-lime"
                style="font-size:0.38em;letter-spacing:0.04em;font-weight:800;"
              >
                スキル
              </span>
              <span style="font-size:0.28em;color:rgba(255,255,255,0.15);font-weight:400;">
                ·
              </span>
            </span>
          ))
        }
      </div>
    </div>
  </div>

  <!-- ── Table ── -->
  <div class="max-w-[1400px] mx-auto px-6 lg:px-[60px] reveal-up">
    <!-- Column headers -->
    <div class="skill-grid border-t border-b border-border py-3 mb-0">
      <span class="col-th">{t('skills.col.tech')}</span>
      <span class="col-th hidden sm:block">{t('skills.col.cat')}</span>
      <span class="col-th hidden md:block">{t('skills.col.level')}</span>
      <span class="col-th text-right">{t('skills.col.prof')}</span>
    </div>

    <!-- Skill rows -->
    {
      skills.map((s, i) => (
        <div
          class="skill-row skill-grid border-b border-border/25 py-[14px] lg:py-[17px] items-center"
          style={`--i:${i}`}
        >
          <span class="text-[13px] lg:text-[14px] text-white/80 tracking-[-0.01em] font-sans">
            {s.name}
          </span>

          <span class="hidden sm:flex">
            <span class="text-[8px] tracking-[0.14em] uppercase px-[8px] py-[4px] border border-border/50 text-muted/60 whitespace-nowrap">
              {s.cat}
            </span>
          </span>

          <span
            class={`hidden md:block text-[10px] tracking-[0.1em] uppercase font-medium
              ${s.level === "Expert" ? "text-lime" : s.level === "Senior" ? "text-white/45" : "text-muted/40"}`}
          >
            {s.level}
          </span>

          <div class="flex items-center gap-3 justify-end">
            <div
              class="relative h-[1px] overflow-hidden flex-1 max-w-[72px] hidden xs:block"
              style="background:rgba(255,255,255,0.08);"
            >
              <div
                class="skill-bar-fill absolute inset-y-0 left-0 bg-lime"
                style="width:0;box-shadow:0 0 6px rgba(180,223,0,0.5);"
                data-pct={s.pct}
              />
            </div>
            <span class="text-[11px] lg:text-[12px] text-lime font-syne tabular-nums w-[34px] text-right">
              {s.pct}%
            </span>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .section-label {
    @apply text-[10px] tracking-[0.25em] text-lime uppercase flex items-center gap-3 mb-[14px];
  }
  .section-label::after {
    content: "";
    @apply block w-[40px] h-px bg-lime;
  }

  /* ── Marquee ── */
  @keyframes skills-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  .skills-track {
    animation: skills-scroll 18s linear infinite;
    will-change: transform;
  }
  .skills-marquee:hover .skills-track {
    animation-play-state: paused;
  }

  /* ── Skill table grid ── */
  .skill-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px 16px;
    align-items: center;
  }
  @media (min-width: 640px) {
    .skill-grid {
      grid-template-columns: 1fr 110px auto;
      gap: 12px 24px;
    }
  }
  @media (min-width: 768px) {
    .skill-grid {
      grid-template-columns: 1fr 120px 80px auto;
      gap: 12px 32px;
    }
  }

  .col-th {
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.28);
  }

  /* ── Row reveal stagger ── */
  @media (min-width: 1024px) {
    .skill-row {
      opacity: 0;
      transform: translateY(10px);
      transition:
        opacity 0.5s ease calc(var(--i) * 45ms),
        transform 0.5s ease calc(var(--i) * 45ms);
    }
    .skills-visible .skill-row {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .skill-bar-fill {
    transition: width 1.1s cubic-bezier(0.23, 1, 0.32, 1);
    transition-delay: calc(var(--i, 0) * 55ms + 200ms);
  }

  /* ── Section reveals ── */
  @media (min-width: 1024px) {
    .reveal {
      @apply opacity-0 translate-y-[20px] transition-[opacity,transform] duration-[600ms] [transition-timing-function:cubic-bezier(0.23,1,0.32,1)];
    }
    .reveal.visible {
      @apply opacity-100 translate-y-0;
    }

    .reveal-up {
      @apply opacity-0 translate-y-[20px] transition-[opacity,transform] duration-[600ms] delay-150 [transition-timing-function:cubic-bezier(0.23,1,0.32,1)];
    }
    .reveal-up.visible {
      @apply opacity-100 translate-y-0;
    }
  }
</style>

<script>
  const section = document.getElementById("skills")!;
  const reveals = section.querySelectorAll<HTMLElement>(".reveal");
  const tableEl = section.querySelector<HTMLElement>(".reveal-up");
  const fills = section.querySelectorAll<HTMLElement>(".skill-bar-fill");

  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add("visible");

        if (entry.target === tableEl) {
          section.classList.add("skills-visible");
          fills.forEach((fill) => {
            fill.style.width = `${fill.dataset.pct ?? 0}%`;
          });
        }

        io.unobserve(entry.target);
      });
    },
    { threshold: 0.04, rootMargin: "0px 0px -30px 0px" },
  );

  reveals.forEach((el) => io.observe(el));
  if (tableEl) io.observe(tableEl);
</script>
