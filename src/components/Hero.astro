---
import portrait from "../assets/images/foto_portrait_kevin.jpeg";
---

<section
  id="hero"
  class="relative w-full h-screen overflow-hidden flex flex-col justify-end"
  aria-labelledby="hero-heading"
>
  <!-- Background 3D animation -->
  <div class="absolute inset-0" aria-hidden="true">
    <iframe
      src="https://my.spline.design/animatedshapeblend-NZa3aGqZlc4TQObjvJlEW2RU/"
      title="Animación 3D decorativa"
      loading="lazy"
      width="100%"
      height="100%"
      class="w-full h-full border-none pointer-events-auto"></iframe>
  </div>

  <!-- Canvas particles -->
  <canvas
    id="particles"
    class="absolute inset-0 pointer-events-none z-[5]"
    aria-hidden="true"></canvas>

  <!-- Gradient overlay -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(to bottom, rgba(3,3,3,0) 30%, rgba(3,3,3,0.5) 60%, #030303 100%);"
    aria-hidden="true"
  >
  </div>

  <!-- Role cycling — above the green bar -->
  <div class="relative z-10 w-full pointer-events-none py-8">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-[40px]">
      <div
        class="flex flex-col gap-0.5 mb-4 opacity-0 translate-y-5 [animation:fadeUp_0.8s_forwards_0.6s]"
        aria-live="polite"
        aria-atomic="true"
      >
        <span
          class="hero-role hero-role-active text-[clamp(11px,1.3vw,16px)] text-text transition-colors duration-500"
          data-i18n="hero.role1">Frontend &amp; Backend Development</span
        >
        <span
          class="hero-role text-[clamp(11px,1.3vw,16px)] text-white transition-colors duration-500"
          data-i18n="hero.role2">Headless CMS &amp; Integración de APIs</span
        >
        <span
          class="hero-role text-[clamp(11px,1.3vw,16px)] text-white transition-colors duration-500"
          data-i18n="hero.role3">E-Commerce &amp; Soluciones Web</span
        >
      </div>
    </div>
  </div>

  <!-- Tech stack bar — static, inside container -->
  <div
    class="relative z-10 w-full py-3 pointer-events-none md:block hidden"
    aria-hidden="true"
  >
    <div class="max-w-[1400px] mx-auto px-6 py-2 lg:px-[60px] bg-lime">
      <div class="flex items-center gap-6 md:gap-8 flex-wrap">
        {
          [
            "Next.js",
            "React",
            "NestJS",
            "Astro",
            "Laravel",
            "WordPress Headless",
            "TypeScript",
            "Node.js",
          ].map((item: string, i: number, arr: string[]) => (
            <span class="flex items-center gap-6 md:gap-8">
              <span class="text-[11px] md:text-[12px] tracking-widest uppercase text-black font-semibold whitespace-nowrap">
                {item}
              </span>
              {i < arr.length - 1 && (
                <span class="text-black/30 text-[10px]">/</span>
              )}
            </span>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Big name -->
  <div class="relative z-10 w-full py-10 md:py-14 pointer-events-none">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-[40px]">
      <h1
        id="hero-heading"
        class="hero-title-anim font-display font-bold leading-[0.88] text-white tracking-tightest uppercase"
        style="font-size: clamp(4.5rem, 10vw, 16rem); font-optical-sizing: auto; font-variation-settings: 'opsz' 32;"
      >
        Kevin <span class="text-lime">Gomez.</span>
      </h1>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="hidden sm:flex absolute bottom-8 md:bottom-10 right-0 pr-6 lg:pr-[60px] items-end gap-3
           text-[10px] tracking-[0.15em] text-muted uppercase pointer-events-none
           opacity-0 [animation:fadeUp_0.8s_forwards_1.3s]"
    aria-hidden="true"
  >
    <span data-i18n="hero.scroll">Explorar</span>
    <div
      class="w-px h-10 [background:linear-gradient(to_bottom,#b4df00,transparent)] [animation:scrollPulse_2s_ease-in-out_infinite]"
    >
    </div>
  </div>
</section>

<style>
  .hero-role.hero-role-active {
    color: #e8e8e8;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes scrollPulse {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 1;
    }
  }
</style>
