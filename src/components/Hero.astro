---
import portrait from "../assets/images/foto_portrait_kevin.jpeg";
import { useTranslations } from "../i18n/utils";

const locale = (Astro.currentLocale || "es") as "es" | "en";
const t = useTranslations(locale);
---

<section
  id="hero"
  class="relative w-full h-screen overflow-hidden flex flex-col justify-end"
  aria-labelledby="hero-heading"
>
  <!-- Background 3D animation — desktop only, deferred -->
  <div class="absolute inset-0" aria-hidden="true" id="hero-spline-container">
    <!-- CSS gradient fallback shown on mobile and before Spline loads -->
    <div
      id="hero-gradient-bg"
      class="w-full h-full"
      style="background: radial-gradient(ellipse 80% 60% at 60% 40%, rgba(180,223,0,0.08) 0%, rgba(3,3,3,0) 70%), radial-gradient(ellipse 50% 50% at 80% 20%, rgba(180,223,0,0.05) 0%, transparent 60%), #030303;"
    >
    </div>
  </div>

  <!-- Canvas particles -->
  <canvas
    id="particles"
    class="absolute inset-0 pointer-events-none z-[5]"
    aria-hidden="true"></canvas>

  <!-- Gradient overlay -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(to bottom, rgba(3,3,3,0) 30%, rgba(3,3,3,0.5) 60%, #030303 100%);"
    aria-hidden="true"
  >
  </div>

  <!-- Role cycling — above the green bar -->
  <div class="relative z-10 w-full pointer-events-none py-8">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-[40px]">
      <div
        class="flex flex-col gap-0.5 mb-4"
        data-hero-reveal="roles"
        aria-live="polite"
        aria-atomic="true"
      >
        <span
          class="hero-role hero-role-active text-[clamp(11px,1.3vw,16px)] text-text transition-colors duration-500"
          >{t("hero.role1")}</span
        >
        <span
          class="hero-role text-[clamp(11px,1.3vw,16px)] text-white transition-colors duration-500"
          >{t("hero.role2")}</span
        >
        <span
          class="hero-role text-[clamp(11px,1.3vw,16px)] text-white transition-colors duration-500"
          >{t("hero.role3")}</span
        >
      </div>
    </div>
  </div>

  <!-- Tech stack bar — static, inside container -->
  <div
    class="relative z-10 w-full py-3 pointer-events-none md:block hidden"
    data-hero-reveal="tech"
    aria-hidden="true"
  >
    <div class="max-w-[1400px] mx-auto px-6 py-2 lg:px-[60px] bg-lime">
      <div class="flex items-center gap-6 md:gap-8 flex-wrap">
        {
          [
            "Next.js",
            "React",
            "NestJS",
            "Astro",
            "Laravel",
            "WordPress Headless",
            "TypeScript",
            "Node.js",
            "Pug",
          ].map((item: string, i: number, arr: string[]) => (
            <span class="flex items-center gap-6 md:gap-8">
              <span class="text-[11px] md:text-[12px] tracking-widest uppercase text-black font-semibold whitespace-nowrap">
                {item}
              </span>
              {i < arr.length - 1 && (
                <span class="text-black/30 text-[10px]">/</span>
              )}
            </span>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Big name -->
  <div class="relative z-10 w-full py-10 md:py-14 pointer-events-none">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-[40px]">
      <h1
        id="hero-heading"
        class="hero-title-anim font-display font-bold leading-[0.88] text-white tracking-tightest uppercase"
        style="font-size: clamp(3rem, 8vw, 8rem); font-optical-sizing: auto; font-variation-settings: 'opsz' 32;"
      >
        Kevin<span class="text-lime">Gomez.</span>ケビン
      </h1>
      <p
        class="mt-3 text-[11px] tracking-[0.18em]"
        style="color:rgba(255,255,255,0.22);"
        data-hero-reveal="secondary"
      >
        ケビン・ゴメス &nbsp;—&nbsp; ウェブ開発者
      </p>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="hidden sm:flex absolute bottom-8 md:bottom-10 right-0 pr-6 lg:pr-[60px] items-end gap-3
           text-[10px] tracking-[0.15em] text-muted uppercase pointer-events-none"
    data-hero-reveal="secondary"
    aria-hidden="true"
  >
    <span>{t("hero.scroll")}</span>
    <div
      class="w-px h-10 [background:linear-gradient(to_bottom,#b4df00,transparent)] [animation:scrollPulse_2s_ease-in-out_infinite]"
    >
    </div>
  </div>
</section>

<style>
  .hero-role.hero-role-active {
    color: #e8e8e8;
  }

  @keyframes scrollPulse {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 1;
    }
  }
</style>

<script>
  // ── Spline 3D: defer on all devices ────────────────
  const container = document.getElementById("hero-spline-container");
  const gradientBg = document.getElementById("hero-gradient-bg");

  if (container) {
    let loaded = false;

    const loadSpline = () => {
      if (loaded) return;
      loaded = true;

      const iframe = document.createElement("iframe");
      iframe.src =
        "https://my.spline.design/animatedshapeblend-NZa3aGqZlc4TQObjvJlEW2RU/";
      iframe.title = "Animación 3D decorativa";
      iframe.className = "w-full h-full border-none pointer-events-auto";
      iframe.style.cssText =
        "position:absolute;inset:0;opacity:0;transition:opacity 1s ease;";
      iframe.onload = () => {
        iframe.style.opacity = "1";
      };

      if (gradientBg) {
        container.insertBefore(iframe, gradientBg);
      } else {
        container.appendChild(iframe);
      }
    };

    // Load during browser idle time so Spline's heavy runtime doesn't block TTI.
    // requestIdleCallback fires when the main thread is free; 10 s hard timeout as fallback.
    const scheduleSpline = () => {
      if ("requestIdleCallback" in window) {
        (window as any).requestIdleCallback(loadSpline, { timeout: 10000 });
      } else {
        setTimeout(loadSpline, 8000);
      }
    };

    document.addEventListener("hero:reveal-spline", scheduleSpline, { once: true });
    scheduleSpline();
  }
</script>

