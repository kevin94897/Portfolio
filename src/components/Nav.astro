---
// Nav.astro — Fixed navigation with language toggle, scroll effect and container
import { Image } from "astro:assets";
import logo from "../assets/images/logo-kevin.png";
import { useTranslations } from "../i18n/utils";

const locale = (Astro.currentLocale || "es") as "es" | "en";
const t = useTranslations(locale);
const isEn = locale === "en";
---

<header>
  <nav
    id="nav"
    aria-label="Navegación principal"
    class="fixed top-0 left-0 right-0 z-[900] transition-[background,backdrop-filter] duration-400"
  >
    <div class="max-w-[1400px] mx-auto px-6 lg:px-[60px]">
      <div
        id="nav-inner"
        class="flex items-center justify-between py-4 lg:py-[22px] transition-[padding] duration-400"
      >
        <!-- Logo -->
        <a
          href="#hero"
          aria-label="Kevin Gómez — Inicio"
          class="nav-logo z-10 relative"
        >
          <Image
            src={logo}
            alt="Logo KG"
            class="h-12 w-auto"
            height={48}
            loading="eager"
            fetchpriority="high"
          />
        </a>

        <!-- Desktop links -->
        <ul class="hidden lg:flex gap-8 list-none" role="list">
          <li>
            <a href="#about" class="nav-link">{t("nav.about")}</a>
          </li>
          <li>
            <a href="#experience" class="nav-link">{t("nav.experience")}</a>
          </li>
          <li>
            <a href="#projects" class="nav-link">{t("nav.projects")}</a>
          </li>
          <li>
            <a href="#workflow" class="nav-link">{t("nav.workflow")}</a>
          </li>
          <li>
            <a href="#contact" class="nav-link">{t("nav.contact")}</a>
          </li>
        </ul>

        <!-- Actions (desktop) + hamburger (mobile) -->
        <div class="flex items-center gap-2">
          <!-- Lang toggle -->
          <div
            class="flex items-center bg-surface2 border border-border overflow-hidden h-9"
            role="group"
            aria-label={isEn ? "Change language" : "Cambiar idioma"}
          >
            <a
              href="/"
              aria-pressed={!isEn}
              aria-label="Español"
              lang="es"
              class={`lang-btn ${!isEn ? "text-black bg-lime" : "text-white"}`}
              >ES</a
            >
            <a
              href="/en/"
              aria-pressed={isEn}
              aria-label="English"
              lang="en"
              class={`lang-btn ${isEn ? "text-black bg-lime" : "text-white"}`}
              >EN</a
            >
          </div>

          <!-- CV button — desktop only -->
          <a
            href="/files/KevinGomezLazaroCV_2026.pdf"
            download
            aria-label={isEn ? "Download CV 2026" : "Descargar CV 2026"}
            class="hidden lg:flex border border-border text-white px-4 h-9 text-[14px] no-underline uppercase items-center gap-[7px] transition-all duration-300 hover:border-lime hover:text-lime"
          >
            <i class="ph ph-download-simple" aria-hidden="true"></i>
            <span>{t("nav.cv")}</span>
          </a>

          <!-- CTA — desktop only -->
          <a
            href="#contact"
            class="hidden lg:flex bg-lime text-black px-5 h-9 text-[12px] font-semibold no-underline uppercase items-center transition-[box-shadow,transform] duration-300 hover:shadow-[0_0_28px_rgba(180,223,0,0.4)] hover:-translate-y-px"
            >{t("nav.hire")}</a
          >

          <!-- Hamburger — mobile/tablet only -->
          <button
            id="menuBtn"
            type="button"
            aria-label="Abrir menú"
            aria-expanded="false"
            aria-controls="mobile-menu"
            class="lg:hidden flex flex-col justify-center items-center w-9 h-9 gap-[5px] bg-transparent border-none cursor-pointer"
          >
            <span
              class="ham-line block w-5 h-px bg-text transition-all duration-300 origin-center"
            ></span>
            <span
              class="ham-line block w-5 h-px bg-text transition-all duration-300 origin-center"
            ></span>
            <span
              class="ham-line block w-5 h-px bg-text transition-all duration-300 origin-center"
            ></span>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      aria-hidden="true"
      class="lg:hidden overflow-hidden max-h-0 transition-[max-height] duration-500 ease-in-out bg-black/95 backdrop-blur-[24px] md:border-t md:border-border"
    >
      <nav
        class="max-w-[1400px] mx-auto px-6 py-6 flex flex-col gap-1"
        aria-label={isEn ? "Mobile menu" : "Menú móvil"}
      >
        <a href="#about" class="mobile-link" onclick="closeMobileMenu()"
          >{t("nav.about")}</a
        >
        <a href="#experience" class="mobile-link" onclick="closeMobileMenu()"
          >{t("nav.experience")}</a
        >
        <a href="#projects" class="mobile-link" onclick="closeMobileMenu()"
          >{t("nav.projects")}</a
        >
        <a href="#contact" class="mobile-link" onclick="closeMobileMenu()"
          >{t("nav.contact")}</a
        >
        <div class="flex gap-3 mt-4 pt-4 border-t border-border">
          <a
            href="/files/KevinGomezLazaroCV_2026.pdf"
            download
            class="flex-1 flex items-center justify-center gap-2 h-10 border border-border text-[12px] font-semibold tracking-tight no-underline uppercase hover:border-lime hover:text-lime transition-all duration-300"
          >
            <span>{t("nav.cv")}</span>
          </a>
          <a
            href="#contact"
            class="flex-1 flex items-center justify-center bg-lime text-black h-10 text-[12px] font-medium no-underline uppercase tracking-tight"
            >{t("nav.hire")}</a
          >
        </div>
      </nav>
    </div>
  </nav>
</header>

<style>
  .nav-link {
    @apply text-[14px] font-semibold text-white no-underline tracking-tight uppercase
           transition-colors duration-200 relative;
  }
  .nav-link::after {
    content: "";
    @apply absolute -bottom-1 left-0 w-0 h-px bg-lime transition-[width] duration-300;
  }
  .nav-link:hover {
    @apply text-lime;
  }
  .nav-link:hover::after {
    @apply w-full;
  }
  .nav-link:focus-visible {
    @apply outline outline-2 outline-lime outline-offset-4 rounded-sm;
  }

  .mobile-link {
    @apply text-[13px] font-semibold no-underline tracking-[0.1em] uppercase tracking-tight
           py-3 border-b border-border/50 transition-colors duration-200 hover:text-lime;
  }

  .lang-btn {
    @apply text-[12px] tracking-wide font-medium px-3 h-full flex items-center justify-center
           bg-transparent border-none cursor-none uppercase transition-all duration-[250ms];
  }
  .lang-btn[aria-pressed="true"] {
    @apply bg-lime text-black;
  }
  .lang-btn:hover:not([aria-pressed="true"]) {
    @apply text-white;
  }

  #nav.scrolled {
    background: rgba(3, 3, 3, 0.9);
    -webkit-backdrop-filter: blur(24px);
    backdrop-filter: blur(24px);
    @apply border-b border-border;
  }
  #nav.scrolled #nav-inner {
    @apply py-3 lg:py-[13px];
  }

  /* Hamburger open state — all lines same width + centered origin */
  #menuBtn[aria-expanded="true"] .ham-line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  #menuBtn[aria-expanded="true"] .ham-line:nth-child(2) {
    @apply opacity-0 scale-x-0;
  }
  #menuBtn[aria-expanded="true"] .ham-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }
</style>

<script>
  const nav = document.getElementById("nav")!;
  const menuBtn = document.getElementById("menuBtn")!;
  const mobileMenu = document.getElementById("mobile-menu")!;

  // Scroll shrink
  const onScroll = () => nav.classList.toggle("scrolled", window.scrollY > 40);
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  // Close helper
  function closeMobileMenu() {
    menuBtn.setAttribute("aria-expanded", "false");
    menuBtn.setAttribute("aria-label", "Abrir menú");
    mobileMenu.setAttribute("aria-hidden", "true");
    mobileMenu.style.maxHeight = "0";
  }

  // Hamburger toggle
  menuBtn.addEventListener("click", () => {
    const open = menuBtn.getAttribute("aria-expanded") === "true";
    if (open) {
      closeMobileMenu();
    } else {
      menuBtn.setAttribute("aria-expanded", "true");
      menuBtn.setAttribute("aria-label", "Cerrar menú");
      mobileMenu.setAttribute("aria-hidden", "false");
      mobileMenu.style.maxHeight = mobileMenu.scrollHeight + "px";
    }
  });

  // Close on any mobile menu link click
  mobileMenu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMobileMenu);
  });

  // Close on outside tap
  document.addEventListener("click", (e) => {
    if (
      menuBtn.getAttribute("aria-expanded") === "true" &&
      !nav.contains(e.target as Node)
    ) {
      closeMobileMenu();
    }
  });
</script>
