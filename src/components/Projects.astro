---
import imgLiwilu from "../assets/images/portfolio/Liwilu.webp";
import imgAstra from "../assets/images/portfolio/Astramedical.webp";
import imgWisec from "../assets/images/portfolio/Aiconstruye.webp";
import imgGustos from "../assets/images/portfolio/Gustoscoffee.webp";
import imgWhaticket from "../assets/images/portfolio/whaticket.webp";
import imgChapa from "../assets/images/portfolio/Chapatubeca.webp";
import imgSegway from "../assets/images/portfolio/Segwaysports.webp";
import imgColecciones from "../assets/images/portfolio/KGFront.webp";
import imgKGStore from "../assets/images/portfolio/KGStore.webp";
import imgPuntoAzul from "../assets/images/portfolio/Puntoazul.webp";
import imgCafePlaza from "../assets/images/portfolio/CafePlaza.webp";
import { useTranslations } from '../i18n/utils';

const locale = (Astro.currentLocale || 'es') as 'es' | 'en';
const t = useTranslations(locale);

interface Project {
  img: ImageMetadata;
  category: string;
  name: string;
  descKey: string;
  desc: string;
  stack: string[];
  url: string;
  demo?: { user: string; pass: string };
}


// Pre-translate descriptions so the JSON embedded in the page is already localized
const projects: Project[] = [
  {
    img: imgColecciones,
    category: "SPA",
    name: "Colecciones Grupo Gómez",
    descKey: "p.colecciones.desc",
    desc: t("p.colecciones.desc"),
    stack: ["React", "React Router", "Lucide", "Vercel"],
    url: "https://colecciones.grupo-gomez.com/",
  },
  {
    img: imgLiwilu,
    category: "Headless E-Commerce",
    name: "Liwilu",
    descKey: "p.liwilu.desc",
    desc: t("p.liwilu.desc"),
    stack: ["Next.js", "NestJS", "PrestaShop", "Tailwind"],
    url: "https://liwilu-staging.vercel.app/",
  },
  {
    img: imgKGStore,
    category: "PWA",
    name: "KG Store Admin",
    descKey: "p.kgstore.desc",
    desc: t("p.kgstore.desc"),
    stack: ["React", "Supabase", "PostgreSQL", "Cloudflare"],
    url: "https://kg-admin-delta.vercel.app/",
    demo: { user: "demo", pass: "QCyJ iNW7 sFpl BPPS FoAR cka8" },
  },
  {
    img: imgCafePlaza,
    category: "Corporate",
    name: "Café de la Plaza",
    descKey: "p.cafeplaza.desc",
    desc: t("p.cafeplaza.desc"),
    stack: ["WordPress", "Elementor", "GSAP", "Kinsta"],
    url: "https://cafedelaplazapr.com/",
  },
  {
    img: imgGustos,
    category: "E-Commerce",
    name: "Gustos Coffee Co.",
    descKey: "p.gustos.desc",
    desc: t("p.gustos.desc"),
    stack: ["Shopify", "Vue.js", "Cloudflare", "Apple Pay"],
    url: "https://www.gustoscoffeeco.com/",
  },
  {
    img: imgWisec,
    category: "SSG Landing",
    name: "AIcon",
    descKey: "p.aicon.desc",
    desc: t("p.aicon.desc"),
    stack: ["Astro", "Alpine.js", "Vercel", "AWS"],
    url: "https://landing-wisec.vercel.app/",
  },
  {
    img: imgWhaticket,
    category: "SaaS",
    name: "Whaticket",
    descKey: "p.whaticket.desc",
    desc: t("p.whaticket.desc"),
    stack: ["WordPress", "Elementor", "WP Rocket", "GTM"],
    url: "https://whaticket.com/",
  },
  {
    img: imgAstra,
    category: "Corporate",
    name: "Astra Medical",
    descKey: "p.astra.desc",
    desc: t("p.astra.desc"),
    stack: ["WordPress", "WooCommerce", "PHP", "Yoast SEO"],
    url: "https://www.astra-medical.com/",
  },
  {
    img: imgChapa,
    category: "Education",
    name: "Chapa Tu Beca",
    descKey: "p.chapa.desc",
    desc: t("p.chapa.desc"),
    stack: ["WordPress Multisite", "Elementor", "PHP", "SEO"],
    url: "https://www.chapatubeca.org/",
  },
  {
    img: imgSegway,
    category: "E-Commerce",
    name: "Segway Powersports",
    descKey: "p.segway.desc",
    desc: t("p.segway.desc"),
    stack: ["WordPress", "Elementor", "RankMath", "jQuery"],
    url: "https://segwaypowersports.com.pe/",
  },
  {
    img: imgPuntoAzul,
    category: "SPA",
    name: "Panel PuntoAzul",
    descKey: "p.puntoazul.desc",
    desc: t("p.puntoazul.desc"),
    stack: ["React", "Vite", "Tailwind", "react-day-picker"],
    url: "https://staging.puntoazulrestaurante.com/",
    demo: { user: "demo", pass: "QCyJ iNW7 sFpl BPPS FoAR cka8" },
  },
];

const N = projects.length;
const viewLabel = t('p.view');

---

<!-- Sección ocupa 100vh — el scroll hijack la mantiene fija -->
<section
  id="projects"
  class="relative w-full h-screen overflow-hidden bg-black border-b border-border py-20 flex flex-col"
  aria-labelledby="projects-heading"
>
  <!-- JSON data para el script -->
  <script
    id="proj-data"
    type="application/json"
    is:inline
    set:html={JSON.stringify(
      projects.map((p) => ({
        name: p.name,
        category: p.category,
        descKey: p.descKey,
        desc: p.desc,
        stack: p.stack,
        url: p.url,
        img: p.img.src,
        demo: p.demo ?? null,
      })),
    )}
  />

  <!-- Header -->
  <div
    class="flex items-start justify-between pb-10 md:pb-0 px-6 md:px-10 pt-10 max-w-[1400px] mx-auto w-full"
  >
    <div>
      <p
        class="text-[10px] tracking-[0.25em] uppercase text-lime flex items-center gap-3 mb-2"
      >
        <span>{t('proj.label')}</span>
        <span class="w-8 h-px bg-lime block" aria-hidden="true"></span>
        <span
          style="color:rgba(180,223,0,0.35); font-size:10px; letter-spacing:0.06em; text-transform:none;"
          >作品集</span
        >
      </p>
      <h2
        id="projects-heading"
        class="section-title-anim font-display font-bold tracking-tightest leading-none text-white"
        style="font-size: clamp(2rem, 4.5vw, 4.5rem); font-optical-sizing: auto; font-variation-settings: 'opsz' 32;"
      >
        {t('proj.title')}
      </h2>
    </div>
  </div>

  <!-- Mobile Embla slider (lg:hidden) -->
  <div class="flex-1 lg:hidden min-h-0 flex flex-col">
    <div
      id="emblaProj"
      class="flex-1 min-h-0 overflow-hidden"
      style="touch-action:pan-y;"
      role="region"
      aria-label="Proyectos"
    >
      <div class="flex h-full" id="emblaProjContainer">
        {
          projects.map((p) => (
            <div class="flex-[0_0_88%] min-w-0 pl-4 h-full">
              <div
                class="mob-slide relative h-full rounded-[14px] overflow-hidden"
                data-project={JSON.stringify({
                  name: p.name,
                  category: p.category,
                  descKey: p.descKey,
                  desc: p.desc,
                  stack: p.stack,
                  url: p.url,
                  img: p.img.src,
                  demo: p.demo ?? null,
                })}
                role="button"
                tabindex="0"
                aria-label={`${p.name} — ${p.category}`}
              >
                <img
                  src={p.img.src}
                  alt={p.name}
                  class="w-full h-full object-cover object-top"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/30 to-transparent" />
                <div class="absolute bottom-0 left-0 right-0 p-5">
                  <p class="text-[9px] tracking-[0.18em] uppercase text-lime mb-1">
                    {p.category}
                  </p>
                  <h3
                    class="font-display text-[20px] font-bold text-white leading-tight mb-2"
                    style="font-optical-sizing:auto;"
                  >
                    {p.name}
                  </h3>
                  <div class="flex gap-[4px] flex-wrap">
                    {p.stack.slice(0, 3).map((t) => (
                      <span class="text-[8px] tracking-widest uppercase px-[6px] py-[2px] border border-border text-muted">
                        {t}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
    <!-- Dots -->
    <div
      id="mob-dots"
      class="flex justify-center items-center gap-[7px]"
      style="height:44px;"
    >
      {projects.map((_, i) => <div class="mob-dot" data-idx={String(i)} />)}
    </div>
  </div>

  <!-- Ghost background text -->
  <div
    class="absolute inset-0 flex items-center justify-center pointer-events-none select-none z-[1]"
    aria-hidden="true"
  >
    <span
      class="font-display font-black tracking-tightest leading-none"
      style="font-size: clamp(6rem, 18vw, 22rem); font-optical-sizing: auto; color: rgba(255,255,255,0.015);"
      >WORKS</span
    >
  </div>

  <!-- 3D Slider (LunDev style) -->
  <div
    id="proj-slider"
    class="hidden lg:block"
    style="
      position: absolute;
      width: 200px;
      height: 260px;
      top: 30%;
      left: calc(50% - 100px);
      transform-style: preserve-3d;
      transform: perspective(1000px) rotateX(-16deg) rotateY(0deg);
      z-index: 5;
    "
  >
    {
      projects.map((p, i) => (
        <div
          class="proj-item"
          style={`
          position: absolute;
          inset: 0;
          transform: rotateY(calc(${i} * (360deg / ${N}))) translateZ(520px);
        `}
          data-active={i === 0 ? "true" : "false"}
          data-index={String(i)}
          data-project={JSON.stringify({
            name: p.name,
            category: p.category,
            descKey: p.descKey,
            desc: p.desc,
            stack: p.stack,
            url: p.url,
            img: p.img.src,
            demo: p.demo ?? null,
          })}
          role="button"
          tabindex={i === 0 ? "0" : "-1"}
          aria-label={`${p.name} — ${p.category}`}
        >
          <img
            src={p.img.src}
            alt={p.name}
            class="proj-item-img w-full h-full object-cover object-top"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent proj-item-overlay" />
        </div>
      ))
    }
  </div>

  <!-- Indicador de dirección (dots) -->
  <div
    id="proj-nav-hint"
    class="absolute right-6 md:right-10 inset-y-0 z-20 hidden lg:flex items-center"
    aria-hidden="true"
  >
    <div id="proj-dots-vert" class="flex flex-col gap-[6px]">
      {
        projects.map((_, i) => (
          <div
            class="proj-dot-v"
            data-idx={String(i)}
            style={
              i === 0 ? "background:rgba(180,223,0,0.5); height:14px;" : ""
            }
          />
        ))
      }
    </div>
  </div>

  <!-- Scroll hint -->
  <div
    id="proj-scroll-hint"
    class="absolute z-20 hidden lg:flex flex-col items-center gap-2 pointer-events-none"
    style="bottom: 220px; left: 50%; transform: translateX(-50%); transition: opacity 0.5s ease;"
    aria-hidden="true"
  >
    <span class="text-[9px] tracking-[0.2em] uppercase text-muted/60"
      >Scroll para explorar</span
    >
    <div
      class="w-px h-8 bg-gradient-to-b from-lime/60 to-transparent proj-scroll-pulse"
    >
    </div>
  </div>

  <!-- Panel info inferior -->
  <div
    id="proj-info-panel"
    class="hidden lg:block absolute bottom-0 left-0 right-0 z-10
           bg-gradient-to-t from-black via-black/90 to-transparent"
  >
    <!-- Container limitado -->
    <div class="max-w-[1400px] mx-auto px-6 md:px-10 pt-6 pb-7">
      <div id="proj-info-content">
        <!-- Category -->
        <p
          id="proj-info-cat"
          class="text-[10px] tracking-[0.2em] uppercase text-lime mb-2"
        >
        </p>

        <!-- Name + stack + link -->
        <div
          class="flex flex-col md:flex-row md:items-end justify-between gap-4"
        >
          <div class="flex-1 min-w-0">
            <h3
              id="proj-info-name"
              class="font-display font-semibold text-white tracking-tightest leading-none mb-2"
              style="font-size: clamp(1.2rem, 2.6vw, 2.2rem); font-optical-sizing: auto;"
            >
            </h3>
            <p
              id="proj-info-desc"
              class="text-muted text-[12px] md:text-[13px] leading-relaxed proj-desc-clamp"
            >
            </p>
          </div>
          <div
            class="flex flex-col items-start md:items-end gap-3 flex-shrink-0"
          >
            <div
              id="proj-info-stack"
              class="flex flex-wrap gap-[5px] md:justify-end"
            >
            </div>
            <a
              id="proj-info-link"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-[10px] bg-lime text-black
                   text-[10px] tracking-[0.12em] uppercase font-medium no-underline
                   transition-all duration-200 hover:opacity-90"
            >
              <span>{viewLabel}</span>
              <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
            </a>
          </div>
        </div>

        <!-- Progress -->
        <div class="flex items-center gap-4 mt-4">
          <div class="flex-1 h-px bg-border relative overflow-hidden">
            <div
              id="proj-progress-fill"
              class="absolute left-0 top-0 h-full bg-lime"
              style="width: 0%;"
            >
            </div>
          </div>
          <span
            id="proj-counter"
            class="text-[10px] tracking-widest text-muted whitespace-nowrap font-display"
          >
            01 / {String(N).padStart(2, "0")}
          </span>
        </div>
      </div>
    </div><!-- /container -->
  </div>
</section>

<!-- Modal -->
<div
  id="proj-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
  class="fixed inset-0 z-[9000] flex items-center justify-center p-4 lg:p-8
         opacity-0 invisible pointer-events-none transition-[opacity,visibility] duration-300"
>
  <div
    id="modal-backdrop"
    class="absolute inset-0 bg-black/80 backdrop-blur-[6px]"
  >
  </div>
  <div
    class="modal-panel relative w-full max-w-[680px] max-h-[90vh] overflow-y-auto
              bg-surface2 border border-border
              translate-y-[30px] transition-transform duration-300
              shadow-[0_40px_100px_rgba(0,0,0,0.7)]"
  >
    <button
      id="modal-close"
      aria-label="Cerrar"
      type="button"
      class="absolute top-3 right-3 lg:top-4 lg:right-4 w-9 h-9 flex items-center justify-center
             border border-border text-muted cursor-pointer
             transition-all duration-200 hover:border-lime/30 hover:text-lime z-10"
    >
      <i class="ph ph-x text-[16px]" aria-hidden="true"></i>
    </button>
    <div class="relative h-[200px] sm:h-[280px] lg:h-[360px] overflow-hidden">
      <img
        id="modal-img"
        src=""
        alt=""
        class="w-full h-full object-cover object-top"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-surface2 via-surface2/20 to-transparent"
      >
      </div>
    </div>
    <div class="px-5 sm:px-7 lg:px-9 pb-6 lg:pb-8 -mt-4 relative">
      <p
        id="modal-category"
        class="text-[9px] tracking-[0.15em] uppercase text-lime mb-2"
      >
      </p>
      <h3
        id="modal-title"
        class="font-display text-[20px] lg:text-[28px] font-bold text-white mb-3 leading-tight"
        style="font-optical-sizing: auto;"
      >
      </h3>
      <p id="modal-desc" class="text-[13px] leading-[1.75] text-text/65 mb-5">
      </p>
      <p class="text-[9px] tracking-[0.2em] uppercase text-muted mb-3">
        Stack Tecnológico
      </p>
      <div
        id="modal-stack"
        class="flex flex-wrap gap-[5px] lg:gap-[6px] mb-5 lg:mb-6"
      >
      </div>
      <div
        id="modal-demo"
        class="hidden mb-6 px-4 py-4 border border-lime/[0.15] bg-lime/[0.04]"
      >
        <p class="text-[9px] tracking-[0.14em] uppercase text-lime/70 mb-3">
          Demo Access
        </p>
        <div class="flex flex-col gap-2">
          <div class="flex items-center gap-3">
            <span class="text-[9px] text-muted w-8">user</span>
            <span
              id="modal-demo-user"
              class="text-[12px] text-text/90 tracking-[0.04em]"></span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-[9px] text-muted w-8">pass</span>
            <span
              id="modal-demo-pass"
              class="text-[12px] text-text/90 tracking-[0.04em] break-all"
            ></span>
          </div>
        </div>
      </div>
      <a
        id="modal-link"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-[8px] px-6 py-[13px] bg-lime text-black
               text-[11px] font-medium tracking-[0.1em] uppercase no-underline
               transition-all duration-200 hover:opacity-90 hover:-translate-y-0.5"
      >
        <span>{viewLabel}</span>
        <i class="ph ph-arrow-up-right" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</div>

<style>
  #projects-heading em {
    color: #b4df00;
    font-style: normal;
  }

  /* 3D slider smooth transition driven by JS */
  #proj-slider {
    transition: transform 0.72s cubic-bezier(0.23, 1, 0.32, 1);
  }

  /* Info panel crossfade */
  #proj-info-content {
    transition: opacity 0.18s ease;
  }

  /* Item image */
  .proj-item-img {
    border-radius: 6px;
    transition: box-shadow 0.4s ease;
    display: block;
  }

  /* Active item: lime glow */
  .proj-item[data-active="true"] .proj-item-img {
    box-shadow:
      0 0 0 2px #b4df00,
      0 0 40px rgba(180, 223, 0, 0.4);
  }

  /* Description clamp */
  .proj-desc-clamp {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Progress bar transition */
  #proj-progress-fill {
    transition: width 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  }

  /* Vertical dots */
  .proj-dot-v {
    width: 3px;
    height: 3px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.1);
    transition:
      background 0.3s ease,
      height 0.3s ease;
  }
  .proj-dot-v.active {
    background: rgba(180, 223, 0, 0.5);
    height: 14px;
  }

  /* Scroll hint pulse */
  @keyframes proj-pulse {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 1;
    }
  }
  .proj-scroll-pulse {
    animation: proj-pulse 1.6s ease-in-out infinite;
  }

  /* Mobile Embla slider */
  .mob-dot {
    width: 6px;
    height: 6px;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.18);
    transition:
      width 0.3s ease,
      background 0.3s ease;
  }
  .mob-dot.active {
    width: 20px;
    background: #b4df00;
  }
  .mob-slide {
    cursor: pointer;
  }

  /* Drag cursor on desktop carousel */
  #proj-slider {
    cursor: grab;
  }
  #proj-slider.dragging {
    cursor: grabbing;
  }

  /* Modal */
  #proj-modal.open {
    @apply opacity-100 visible pointer-events-auto;
  }
  #proj-modal.open .modal-panel {
    @apply translate-y-0;
  }
</style>

<script>
  import EmblaCarousel from "embla-carousel";

  /* ─────────────────────────────────────────────────────────
     DATA & REFS
  ───────────────────────────────────────────────────────── */
  const PROJECTS: any[] = JSON.parse(
    document.getElementById("proj-data")!.textContent || "[]",
  );
  const N = PROJECTS.length;

  const section = document.getElementById("projects")!;
  const slider = document.getElementById("proj-slider")!;
  const items = Array.from(
    document.querySelectorAll<HTMLElement>(".proj-item"),
  );
  const infoCat = document.getElementById("proj-info-cat")!;
  const infoName = document.getElementById("proj-info-name")!;
  const infoDesc = document.getElementById("proj-info-desc")!;
  const infoStack = document.getElementById("proj-info-stack")!;
  const infoLink = document.getElementById(
    "proj-info-link",
  ) as HTMLAnchorElement;
  const infoCont = document.getElementById("proj-info-content")!;
  const fillBar = document.getElementById("proj-progress-fill")!;
  const counter = document.getElementById("proj-counter")!;
  const hint = document.getElementById("proj-scroll-hint")!;
  const dotsVert = Array.from(
    document.querySelectorAll<HTMLElement>(".proj-dot-v"),
  );

  const isMobile = () => window.innerWidth < 1024;

  /* ─────────────────────────────────────────────────────────
     STATE
  ───────────────────────────────────────────────────────── */
  let locked = false; // scroll hijack active
  let cooldown = false; // prevents re-lock immediately after release
  let animating = false; // prevents double-triggering during transition
  let projIdx = 0;
  let crossTimer: ReturnType<typeof setTimeout> | null = null;
  // Drag state
  let isDragging = false;
  let dragMoved = false;
  let dragStartX = 0;
  let dragStartRotY = 0;

  /* ─────────────────────────────────────────────────────────
     CAROUSEL NAVIGATION
  ───────────────────────────────────────────────────────── */
  function goTo(idx: number): void {
    if (animating) return;

    if (idx < 0) {
      releaseUp();
      return;
    }
    if (idx >= N) {
      releaseDown();
      return;
    }

    animating = true;
    projIdx = idx;

    // Rotate cylinder so item idx faces viewer
    const rotateY = -((idx * 360) / N);
    slider.style.transform = `perspective(1000px) rotateX(-16deg) rotateY(${rotateY.toFixed(2)}deg)`;

    // Update info panel with crossfade
    infoCont.style.opacity = "0";
    if (crossTimer) clearTimeout(crossTimer);
    crossTimer = setTimeout(() => {
      const p = PROJECTS[idx];
      infoCat.textContent = p.category;
      infoName.textContent = p.name;
      infoDesc.textContent = p.desc;
      infoLink.href = p.url;

      infoStack.innerHTML = "";
      (p.stack as string[]).forEach((t: string) => {
        const s = document.createElement("span");
        s.className =
          "text-[9px] tracking-widest uppercase px-[7px] py-[3px] border border-border text-muted whitespace-nowrap";
        s.textContent = t;
        infoStack.appendChild(s);
      });

      fillBar.style.width = `${(((idx + 1) / N) * 100).toFixed(1)}%`;
      counter.textContent = `${String(idx + 1).padStart(2, "0")} / ${String(N).padStart(2, "0")}`;

      // Active item glow
      items.forEach((item, i) => {
        item.dataset.active = String(i === idx);
        item.setAttribute("tabindex", i === idx ? "0" : "-1");
      });

      // Vertical dots
      dotsVert.forEach((d, i) => d.classList.toggle("active", i === idx));

      infoCont.style.opacity = "1";
    }, 160);

    // Hide scroll hint once user starts navigating
    if (idx > 0 && hint) hint.style.opacity = "0";

    setTimeout(() => {
      animating = false;
    }, 750);
  }

  /* ─────────────────────────────────────────────────────────
     LOCK / RELEASE
  ───────────────────────────────────────────────────────── */
  function lock(fromBelow: boolean = false): void {
    if (locked || cooldown) return;
    locked = true;

    // If entering from below, start at last project
    const startIdx = fromBelow ? N - 1 : 0;
    projIdx = startIdx;

    // Suppress transitions during snap, then restore
    slider.style.transition = "none";
    const snapRot = -((startIdx * 360) / N);
    slider.style.transform = `perspective(1000px) rotateX(-16deg) rotateY(${snapRot.toFixed(2)}deg)`;
    requestAnimationFrame(() => {
      slider.style.transition = "";
    });

    // Init info panel without crossfade
    infoCont.style.opacity = "1";
    const p = PROJECTS[startIdx];
    infoCat.textContent = p.category;
    infoName.textContent = p.name;
    infoDesc.textContent = p.desc;
    infoLink.href = p.url;
    infoStack.innerHTML = "";
    (p.stack as string[]).forEach((t: string) => {
      const s = document.createElement("span");
      s.className =
        "text-[9px] tracking-widest uppercase px-[7px] py-[3px] border border-border text-muted whitespace-nowrap";
      s.textContent = t;
      infoStack.appendChild(s);
    });
    fillBar.style.width = `${(((startIdx + 1) / N) * 100).toFixed(1)}%`;
    counter.textContent = `${String(startIdx + 1).padStart(2, "0")} / ${String(N).padStart(2, "0")}`;
    items.forEach((item, i) => {
      item.dataset.active = String(i === startIdx);
      item.setAttribute("tabindex", i === startIdx ? "0" : "-1");
    });
    dotsVert.forEach((d, i) => d.classList.toggle("active", i === startIdx));

    if (hint) hint.style.opacity = fromBelow ? "0" : "1";

    // Prevent page scroll
    document.documentElement.style.overflow = "hidden";
  }

  function releaseDown(): void {
    locked = false;
    cooldown = true;
    document.documentElement.style.overflow = "";

    // Scroll to section immediately after projects
    const next = section.nextElementSibling as HTMLElement | null;
    const target = next
      ? next.getBoundingClientRect().top + window.scrollY
      : section.offsetTop + section.offsetHeight;

    setTimeout(() => {
      window.scrollTo({ top: target, behavior: "smooth" });
    }, 40);

    setTimeout(() => {
      cooldown = false;
    }, 1800);
  }

  function releaseUp(): void {
    locked = false;
    cooldown = true;
    document.documentElement.style.overflow = "";

    // Scroll to the section above
    const prev = section.previousElementSibling as HTMLElement | null;
    const target = prev
      ? prev.getBoundingClientRect().top + window.scrollY
      : Math.max(0, section.offsetTop - window.innerHeight);

    setTimeout(() => {
      window.scrollTo({ top: target, behavior: "smooth" });
    }, 40);

    setTimeout(() => {
      goTo(0); // reset carousel for next time
      cooldown = false;
    }, 1800);
  }

  /* ─────────────────────────────────────────────────────────
     TRIGGER LOCK — IntersectionObserver
     Fires when section is ≥ 90% in viewport.
     Detects entry direction via scroll position.
  ───────────────────────────────────────────────────────── */
  let lastScrollY = window.scrollY;
  window.addEventListener(
    "scroll",
    () => {
      lastScrollY = window.scrollY;
    },
    { passive: true },
  );

  const lockIO = new IntersectionObserver(
    ([entry]) => {
      if (
        !entry.isIntersecting ||
        entry.intersectionRatio < 0.9 ||
        cooldown ||
        locked
      )
        return;

      // Snap section perfectly to viewport top
      const off = Math.round(section.getBoundingClientRect().top);
      if (Math.abs(off) > 2) {
        window.scrollTo({ top: window.scrollY + off });
      }

      // Determine approach direction
      const fromBelow =
        lastScrollY > section.offsetTop + section.offsetHeight * 0.5;
      lock(fromBelow);
    },
    { threshold: [0.9] },
  );
  if (!isMobile()) lockIO.observe(section);

  /* ─────────────────────────────────────────────────────────
     INPUT HANDLERS
  ───────────────────────────────────────────────────────── */

  // Mouse wheel
  window.addEventListener(
    "wheel",
    (e: WheelEvent) => {
      if (!locked) return;
      e.preventDefault();
      const dir = e.deltaY > 0 ? 1 : -1;
      goTo(projIdx + dir);
    },
    { passive: false },
  );

  // Touch swipe
  let touchStartY = 0;
  window.addEventListener(
    "touchstart",
    (e) => {
      touchStartY = e.touches[0].clientY;
    },
    { passive: true },
  );

  window.addEventListener(
    "touchmove",
    (e) => {
      if (locked) e.preventDefault();
    },
    { passive: false },
  );

  window.addEventListener("touchend", (e) => {
    if (!locked) return;
    const delta = touchStartY - e.changedTouches[0].clientY;
    if (Math.abs(delta) > 45) goTo(projIdx + (delta > 0 ? 1 : -1));
  });

  // Keyboard
  window.addEventListener("keydown", (e: KeyboardEvent) => {
    if (!locked) return;
    if (e.key === "ArrowDown" || e.key === "PageDown") {
      e.preventDefault();
      goTo(projIdx + 1);
    }
    if (e.key === "ArrowUp" || e.key === "PageUp") {
      e.preventDefault();
      goTo(projIdx - 1);
    }
  });

  // Dot clicks
  dotsVert.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      if (locked) goTo(i);
    });
  });

  // ── Mouse drag (desktop 3D carousel) ──────────────────────
  const DRAG_SENS = 0.3; // degrees per pixel

  slider.addEventListener("mousedown", (e: MouseEvent) => {
    if (isMobile()) return;
    isDragging = true;
    dragMoved = false;
    dragStartX = e.clientX;
    dragStartRotY = -((projIdx * 360) / N);
    slider.style.transition = "none";
    slider.classList.add("dragging");
    e.preventDefault();
  });

  window.addEventListener("mousemove", (e: MouseEvent) => {
    if (!isDragging) return;
    const delta = e.clientX - dragStartX;
    if (Math.abs(delta) > 5) dragMoved = true;
    const rotY = dragStartRotY + delta * DRAG_SENS;
    slider.style.transform = `perspective(1000px) rotateX(-16deg) rotateY(${rotY.toFixed(2)}deg)`;
  });

  window.addEventListener("mouseup", (e: MouseEvent) => {
    if (!isDragging) return;
    isDragging = false;
    slider.classList.remove("dragging");
    slider.style.transition = "";
    if (dragMoved) {
      const delta = e.clientX - dragStartX;
      const currentRotY = dragStartRotY + delta * DRAG_SENS;
      const rawIdx = Math.round((-currentRotY * N) / 360);
      const nearest = Math.max(0, Math.min(N - 1, rawIdx));
      setTimeout(() => {
        dragMoved = false;
      }, 50);
      goTo(nearest);
    }
  });

  // Item clicks → open modal
  items.forEach((item) => {
    item.addEventListener("click", () => {
      if (dragMoved) return;
      openModal(JSON.parse(item.dataset.project!));
    });
    item.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        openModal(JSON.parse(item.dataset.project!));
      }
    });
  });

  /* ─────────────────────────────────────────────────────────
     MODAL
  ───────────────────────────────────────────────────────── */
  const modal = document.getElementById("proj-modal")!;
  const backdrop = document.getElementById("modal-backdrop")!;
  const closeBtn = document.getElementById("modal-close")!;
  const modalImg = document.getElementById("modal-img") as HTMLImageElement;
  const modalCat = document.getElementById("modal-category")!;
  const modalTitle = document.getElementById("modal-title")!;
  const modalDesc = document.getElementById("modal-desc")!;
  const modalStack = document.getElementById("modal-stack")!;
  const modalDemo = document.getElementById("modal-demo")!;
  const modalDemoU = document.getElementById("modal-demo-user")!;
  const modalDemoP = document.getElementById("modal-demo-pass")!;
  const modalLink = document.getElementById("modal-link") as HTMLAnchorElement;

  function openModal(data: any) {
    modalImg.src = data.img;
    modalImg.alt = data.name;
    modalCat.textContent = data.category;
    modalTitle.textContent = data.name;
    modalDesc.textContent = data.desc;
    modalLink.href = data.url;
    modalStack.innerHTML = "";
    (data.stack as string[]).forEach((t: string) => {
      const s = document.createElement("span");
      s.className =
        "text-[10px] tracking-widest uppercase px-[8px] py-[4px] border border-border text-muted";
      s.textContent = t;
      modalStack.appendChild(s);
    });
    if (data.demo) {
      modalDemoU.textContent = data.demo.user;
      modalDemoP.textContent = data.demo.pass;
      modalDemo.classList.remove("hidden");
    } else {
      modalDemo.classList.add("hidden");
    }
    modal.classList.add("open");
    // Don't change body overflow — scroll hijack manages it
  }

  function closeModal() {
    modal.classList.remove("open");
  }

  closeBtn.addEventListener("click", closeModal);
  backdrop.addEventListener("click", closeModal);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });

  // ── Mobile Embla slider ──────────────────────────────────────
  if (isMobile()) {
    const emblaViewport = document.getElementById("emblaProj")!;
    const mobDotEls = Array.from(
      document.querySelectorAll<HTMLElement>(".mob-dot"),
    );

    if (mobDotEls[0]) mobDotEls[0].classList.add("active");

    const emblaProj = EmblaCarousel(emblaViewport, {
      align: "center",
      loop: false,
      dragFree: false,
    });

    emblaProj.on("select", () => {
      const idx = emblaProj.selectedScrollSnap();
      mobDotEls.forEach((d, i) => d.classList.toggle("active", i === idx));
    });

    emblaProj.slideNodes().forEach((slideWrapper) => {
      const card = slideWrapper.querySelector<HTMLElement>(".mob-slide");
      if (!card) return;
      card.addEventListener("click", () => {
        openModal(JSON.parse(card.dataset.project!));
      });
      card.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          openModal(JSON.parse(card.dataset.project!));
        }
      });
    });
  }
</script>
